---
// ============================================================
// MERIDIAN Magazine — Article Page (Dynamic Route)
// ============================================================
// Individual article display page with breadcrumbs, header,
// content (with premium gate), share buttons, author card,
// related articles, and newsletter signup.

import ArticleLayout from '@layouts/ArticleLayout.astro';
import Breadcrumbs from '@components/common/Breadcrumbs.astro';
import CategoryBadge from '@components/common/CategoryBadge.astro';
import PremiumGate from '@components/common/PremiumGate.astro';
import ShareButtons from '@components/common/ShareButtons.astro';
import AuthorCard from '@components/common/AuthorCard.astro';
import ArticleCard from '@components/common/ArticleCard.astro';
import NewsletterSignup from '@components/common/NewsletterSignup.astro';
import { getAllArticles, getArticlePageData } from '@data/service';
import { formatDate, getInitials } from '@utils/helpers';
import type { Article } from '@data/types';

export async function getStaticPaths() {
  const articles = await getAllArticles();
  return articles.map((article) => ({
    params: { slug: article.slug },
  }));
}

const { slug } = Astro.params;
const data = await getArticlePageData(slug!);

if (!data) {
  return Astro.redirect('/404');
}

const { article, related } = data;

// Build breadcrumbs
const breadcrumbItems = [
  { label: 'Home', href: '/' },
  ...(article.category ? [{ label: article.category.name, href: `/categories/${article.category.slug}` }] : []),
  { label: article.title },
];

// Split content for premium gate: first 3 paragraphs as preview
function splitContent(html: string): { preview: string; full: string } {
  const paragraphs = html.split('</p>');
  const previewParagraphs = paragraphs.slice(0, 3);
  const preview = previewParagraphs.join('</p>') + '</p>';
  return { preview, full: html };
}

const { preview, full } = article.access === 'premium' ? splitContent(article.content) : { preview: '', full: article.content };

const initials = getInitials(article.author?.name || 'M');
const canonicalUrl = `https://meridian-mag.com/articles/${article.slug}`;
---

<ArticleLayout article={article}>
  <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 pt-6 pb-16">

    <!-- Breadcrumbs -->
    <div class="mb-8">
      <Breadcrumbs items={breadcrumbItems} />
    </div>

    <!-- Article Header -->
    <header class="mb-10">
      <!-- Category Badge -->
      {article.category && (
        <div class="mb-4">
          <CategoryBadge
            category={article.category}
            variant="filled"
            size="md"
            href={`/categories/${article.category.slug}`}
          />
        </div>
      )}

      <!-- Title -->
      <h1 class="font-editorial text-3xl sm:text-4xl lg:text-5xl font-bold mb-4 leading-tight">
        {article.title}
      </h1>

      <!-- Subtitle -->
      {article.subtitle && (
        <p class="text-xl text-text-secondary dark:text-gray-400 mb-6">
          {article.subtitle}
        </p>
      )}

      <!-- Author + date row -->
      <div class="flex items-center gap-4 mb-8 pb-8 border-b border-border dark:border-gray-800">
        <!-- Author avatar -->
        {article.author?.avatar ? (
          <img
            src={article.author.avatar}
            alt={article.author.name}
            class="w-12 h-12 rounded-full object-cover flex-shrink-0"
            loading="lazy"
          />
        ) : (
          <div class="w-12 h-12 rounded-full bg-gradient-to-br from-accent to-blue-700 flex items-center justify-center text-white text-sm font-bold flex-shrink-0">
            {initials}
          </div>
        )}
        <div>
          {article.author && (
            <a href={`/authors/${article.author.slug}`} class="font-semibold hover:text-accent transition-colors">
              {article.author.name}
            </a>
          )}
          <p class="text-sm text-text-muted dark:text-gray-500">
            {article.author?.role || 'Contributor'} &middot; {formatDate(article.publishedAt, 'medium')} &middot; {article.readingTime} min read
          </p>
        </div>
      </div>

      <!-- Cover Image -->
      <div class="rounded-2xl overflow-hidden mb-6">
        <img
          src={article.coverImage}
          alt={article.title}
          class="w-full h-auto object-cover"
          fetchpriority="high"
          width="1344"
          height="768"
        />
      </div>

      <!-- Cover Caption -->
      {article.coverCaption && (
        <p class="text-xs text-text-muted dark:text-gray-500 italic mb-8">
          {article.coverCaption}
        </p>
      )}
    </header>

    <!-- Article Content -->
    <div class="article-content">
      {article.access === 'premium' ? (
        <PremiumGate previewContent={preview} fullContent={full} />
      ) : (
        <Fragment set:html={article.content} />
      )}
    </div>

    <!-- Article Footer -->
    <footer class="mt-12 pt-8 border-t border-border dark:border-gray-800">

      <!-- Share Buttons -->
      <div class="flex items-center justify-between mb-10">
        <span class="text-sm font-semibold text-text-secondary dark:text-gray-400">Share this article</span>
        <ShareButtons title={article.title} url={canonicalUrl} />
      </div>

      <!-- Author Card -->
      {article.author && (
        <div class="mb-12">
          <AuthorCard author={article.author} />
        </div>
      )}

      <!-- Related Articles -->
      {related.length > 0 && (
        <section class="mb-12">
          <h2 class="font-editorial text-2xl font-bold mb-6">Related Articles</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {related.map((a) => (
              <ArticleCard article={a} variant="grid" />
            ))}
          </div>
        </section>
      )}

      <!-- Newsletter -->
      <NewsletterSignup variant="inline" />
    </footer>
  </article>

  <style is:global>
    @reference "../../styles/global.css";

    .article-content h2 { @apply font-editorial text-2xl font-bold mt-10 mb-4; }
    .article-content h3 { @apply font-editorial text-xl font-bold mt-8 mb-3; }
    .article-content p { @apply mb-5 leading-relaxed text-text-secondary dark:text-gray-300; }
    .article-content blockquote { @apply border-l-4 border-accent pl-6 italic my-8 text-text-secondary dark:text-gray-300; }
    .article-content ul, .article-content ol { @apply mb-5 pl-6 space-y-2 text-text-secondary dark:text-gray-300; }
    .article-content li { @apply leading-relaxed; }
    .article-content img { @apply rounded-xl my-8 w-full; }
    .article-content a { @apply text-accent hover:text-sky-600 underline; }
    .article-content strong { @apply font-semibold text-text-primary dark:text-gray-100; }
    .article-content em { @apply italic; }
    .article-content code { @apply bg-surface-alt dark:bg-gray-800 px-1.5 py-0.5 rounded text-sm font-mono; }
  </style>
</ArticleLayout>
