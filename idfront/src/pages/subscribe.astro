---
/**
 * Subscribe Page — /subscribe
 * Subscription plans, pricing comparison, trust badges, and FAQ.
 * Payment gateway modal with TOC consent on "Subscribe Now" click.
 */

import BaseLayout from '@layouts/BaseLayout.astro';
import SubscribeCTA from '@components/common/SubscribeCTA.astro';
import PlanComparison from '@components/subscription/PlanComparison.astro';
import FAQ from '@components/subscription/FAQ.astro';
import NewsletterSignup from '@components/common/NewsletterSignup.astro';
import { getSiteConfig } from '@data/service';

// Get subscription plans and payment gateways from site config
const { subscriptionPlans: plans, paymentGateways = [], termsOfServiceUrl = '/terms' } = await getSiteConfig();
const enabledGateways = paymentGateways.filter(g => g.enabled);

// SEO
const title = 'Subscribe to MERIDIAN — Unlock Premium Journalism';
const description = 'Get full access to premium journalism, deep dives, and exclusive content. Choose from Free, Premium, and Premium + Print plans.';

// FAQ items
const faqItems = [
  {
    question: "What's included in the free plan?",
    answer: 'The free plan gives you access to all public category articles including World News, Science & Tech, Environment, Sports, Culture, and Health. You also get daily edition summaries, full search capabilities, and our Sunday newsletter with the week\'s top stories.',
  },
  {
    question: 'Can I cancel my subscription anytime?',
    answer: 'Absolutely. You can cancel your subscription at any time from your account settings. If you cancel, you\'ll retain access to premium content until the end of your current billing period. No questions asked, no cancellation fees.',
  },
  {
    question: 'How does the print edition work?',
    answer: 'Premium + Print subscribers receive a beautifully printed weekly magazine delivered to their door. Each edition is printed on demand and shipped within 2–3 business days. You\'ll also receive PDF downloads of every edition for offline reading on any device.',
  },
  {
    question: 'Is there a student discount?',
    answer: 'Yes! We offer a 50% student discount on all premium plans. Simply verify your student status with a valid .edu email address or upload your student ID. The discount applies for the duration of your enrollment.',
  },
  {
    question: 'What payment methods do you accept?',
    answer: 'We accept all major credit and debit cards (Visa, Mastercard, American Express, Discover), PayPal, Apple Pay, and Google Pay. For annual subscriptions, we also support bank transfers and wire payments. All transactions are secured with 256-bit SSL encryption.',
  },
  {
    question: 'Can I switch between plans?',
    answer: 'Yes, you can upgrade or downgrade your plan at any time. When upgrading, you\'ll get immediate access to the new plan\'s features and be charged a prorated amount. When downgrading, the change takes effect at the start of your next billing cycle.',
  },
];

// Serialize gateway data for Alpine.js
// Serialize gateway data for Alpine.js
const gatewaysJson = JSON.stringify(enabledGateways.map(g => ({
  id: g.id,
  name: g.name,
  description: g.description,
  icon: g.icon,
  paymentLink: g.paymentLink,
})));

// Serialize plans for auto-open from URL param
const plansJson = JSON.stringify(plans.map(p => ({
  id: p.id,
  name: p.name,
  price: p.price,
  interval: p.interval,
})));

---

<BaseLayout title={title} description={description} canonicalUrl="/subscribe">
  <div class="page-transition">

    <!-- ==================== Hero Header ==================== -->
    <section class="bg-gradient-to-br from-primary via-secondary to-primary py-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <!-- Floating subscriber badge -->
        <span class="inline-flex items-center gap-2 px-4 py-1.5 bg-white/10 border border-white/20 rounded-full text-white text-sm font-medium mb-6">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          250,000+ subscribers
        </span>

        <h1 class="font-editorial text-4xl sm:text-5xl font-bold text-white mb-4">
          Unlock MERIDIAN
        </h1>
        <p class="text-gray-300 text-lg sm:text-xl max-w-2xl mx-auto">
          Get full access to premium journalism, deep dives, and exclusive content.
        </p>
      </div>
    </section>

    <!-- ==================== Pricing Section ==================== -->
    <section class="py-16 bg-white dark:bg-gray-950">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="font-editorial text-3xl sm:text-4xl font-bold mb-3">Choose Your Plan</h2>
          <p class="text-text-secondary dark:text-gray-400 max-w-xl mx-auto">
            From free exploration to full print subscriptions — find the right plan for you.
          </p>
        </div>

        <!-- Pricing cards -->
        <div class="max-w-6xl mx-auto">
          <SubscribeCTA plans={plans} gateways={enabledGateways} />
        </div>
      </div>
    </section>

    <!-- ==================== Money-Back Guarantee ==================== -->
    <section class="py-12 bg-surface dark:bg-gray-900 border-y border-border dark:border-gray-800">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 text-center">
          <!-- Shield icon -->
          <div class="flex-shrink-0 w-14 h-14 rounded-full bg-accent/10 dark:bg-accent/10 flex items-center justify-center">
            <svg class="w-7 h-7 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <!-- Text -->
          <div>
            <h3 class="font-semibold text-lg text-text-primary dark:text-gray-100">
              30-Day Money-Back Guarantee
            </h3>
            <p class="text-text-secondary dark:text-gray-400 text-sm mt-1">
              Not satisfied? Get a full refund within 30 days, no questions asked.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ==================== Comparison Table ==================== -->
    <section class="py-16 bg-white dark:bg-gray-950">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="font-editorial text-3xl sm:text-4xl font-bold text-center mb-3">
          Compare Plans
        </h2>
        <p class="text-text-secondary dark:text-gray-400 text-center mb-10 max-w-xl mx-auto">
          See exactly what's included in each plan at a glance.
        </p>

        <div class="bg-white dark:bg-gray-900 rounded-2xl border border-border dark:border-gray-700 overflow-hidden shadow-sm">
          <PlanComparison plans={plans} />
        </div>
      </div>
    </section>

    <!-- ==================== FAQ Section ==================== -->
    <section class="py-16 bg-surface dark:bg-gray-900">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="font-editorial text-3xl sm:text-4xl font-bold text-center mb-3">
          Frequently Asked Questions
        </h2>
        <p class="text-text-secondary dark:text-gray-400 text-center mb-10">
          Everything you need to know about subscribing to MERIDIAN.
        </p>

        <FAQ items={faqItems} />
      </div>
    </section>

    <!-- ==================== Newsletter CTA ==================== -->
    <NewsletterSignup variant="section" />

  </div>

  <!-- ==================== Payment Gateway Modal (global) ==================== -->
  <div
    x-data={`subscribeModal(${gatewaysJson}, ${plansJson})`}
    x-show="showPaymentModal"
    x-cloak
    x-init="init()"
    class="fixed inset-0 z-50 flex items-center justify-center p-4"
    @keydown.escape.window="showPaymentModal = false"
  >
    <!-- Backdrop -->
    <div class="fixed inset-0 bg-black/50" @click="showPaymentModal = false"></div>
    <!-- Modal -->
    <div class="relative bg-white dark:bg-gray-900 rounded-2xl border border-border dark:border-gray-800 p-6 w-full max-w-lg shadow-xl z-10 max-h-[90vh] overflow-y-auto"
      x-transition:enter="transition ease-out duration-200"
      x-transition:enter-start="opacity-0 scale-95"
      x-transition:enter-end="opacity-100 scale-100"
      x-transition:leave="transition ease-in duration-150"
      x-transition:leave-start="opacity-100 scale-100"
      x-transition:leave-end="opacity-0 scale-95"
    >
      <!-- Close button -->
      <button @click="showPaymentModal = false" class="absolute top-4 right-4 text-text-muted dark:text-gray-500 hover:text-primary dark:hover:text-white transition-colors">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>

      <h3 class="font-editorial text-xl font-bold text-primary dark:text-white pr-8">
        Subscribe to <span x-text="selectedPlanName"></span>
      </h3>
      <p class="text-sm text-text-secondary dark:text-gray-400 mt-1">
        Choose a payment method to complete your subscription.
      </p>

      <!-- Plan Summary in Modal -->
      <div class="mt-4 bg-surface-alt dark:bg-gray-800 rounded-lg p-4">
        <h4 class="text-xs font-semibold text-text-muted dark:text-gray-500 uppercase tracking-wider mb-2">Plan Details</h4>
        <div class="flex justify-between items-center">
          <span class="text-text-secondary dark:text-gray-400 text-sm" x-text="selectedPlanName"></span>
          <span class="text-accent font-bold text-lg" x-text="`$${selectedPlanPrice}/${selectedPlanInterval}`"></span>
        </div>
      </div>

      <!-- Terms of Service Consent -->
      <div class="mt-5">
        <label class="flex items-start gap-3 cursor-pointer group">
          <input
            type="checkbox"
            x-model="tocConsent"
            class="mt-1 w-4 h-4 rounded border-border dark:border-gray-600 text-accent focus:ring-accent"
          />
          <span class="text-sm text-text-secondary dark:text-gray-400 group-hover:text-primary dark:group-hover:text-gray-300 transition-colors">
            I agree to the <a href="/terms" target="_blank" class="text-accent hover:underline">Terms of Service</a> and <a href="/privacy" target="_blank" class="text-accent hover:underline">Privacy Policy</a>. I understand this will start a recurring subscription that can be cancelled at any time.
          </span>
        </label>
      </div>

      <!-- Payment Gateway Selection -->
      <div class="mt-5">
        <h4 class="text-sm font-semibold text-primary dark:text-white mb-3">
          Select Payment Method
        </h4>
        <div class="space-y-2">
          <template x-for="gateway in gateways" :key="gateway.id">
            <label
              :class="selectedGateway === gateway.id ? 'border-accent bg-accent/5 dark:bg-accent/10 ring-1 ring-accent' : 'border-border dark:border-gray-700 hover:border-accent/50 dark:hover:border-accent/50'"
              class="flex items-center gap-4 p-4 rounded-xl border cursor-pointer transition-all"
            >
              <input
                type="radio"
                name="subscribe-gateway"
                :value="gateway.id"
                x-model="selectedGateway"
                class="w-4 h-4 text-accent focus:ring-accent"
              />
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2">
                  <template x-if="gateway.icon === 'stripe'">
                    <span class="text-sm font-bold text-indigo-600 dark:text-indigo-400">Stripe</span>
                  </template>
                  <template x-if="gateway.icon === 'paypal'">
                    <span class="text-sm font-bold text-blue-600 dark:text-blue-400">PayPal</span>
                  </template>
                  <template x-if="gateway.icon !== 'stripe' && gateway.icon !== 'paypal'">
                    <span class="text-sm font-semibold text-primary dark:text-white" x-text="gateway.name"></span>
                  </template>
                </div>
                <p class="text-xs text-text-muted dark:text-gray-500 mt-0.5" x-text="gateway.description"></p>
              </div>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-text-muted dark:text-gray-500 shrink-0">
                <path d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
              </svg>
            </label>
          </template>
        </div>
      </div>

      <!-- Proceed to Payment Button -->
      <button
        @click="proceedToPayment()"
        :disabled="!tocConsent || !selectedGateway"
        class="mt-6 w-full bg-accent hover:bg-sky-600 disabled:bg-gray-300 dark:disabled:bg-gray-700 disabled:cursor-not-allowed text-white font-semibold py-3.5 rounded-xl text-sm transition-colors flex items-center justify-center gap-2"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
        <span>Proceed to Payment</span>
      </button>

      <p class="text-xs text-text-muted dark:text-gray-500 text-center mt-3">
        You will be redirected to the payment gateway to complete your subscription securely.
      </p>
    </div>
  </div>

  <!-- Shared Alpine.js Subscribe Modal Component -->
  <script is:inline>
    function subscribeModal(gatewaysData, plansData) {
      return {
        gateways: gatewaysData || [],
        plans: plansData || [],
        showPaymentModal: false,
        selectedGateway: '',
        tocConsent: false,
        selectedPlanId: '',
        selectedPlanName: '',
        selectedPlanPrice: 0,
        selectedPlanInterval: 'monthly',

        init() {
          // Auto-open modal if ?plan=xxx is in the URL
          const params = new URLSearchParams(window.location.search);
          const planId = params.get('plan');
          if (planId) {
            const plan = this.plans.find(p => p.id === planId);
            if (plan) {
              this.openModal(plan.id, plan.name, plan.price, plan.interval);
              // Clean up URL without page reload
              window.history.replaceState({}, '', window.location.pathname);
            }
          }

          // Listen for open-subscribe-modal events (from SubscribeCTA buttons)
          window.addEventListener('open-subscribe-modal', (e) => {
            const d = e.detail || {};
            this.openModal(d.planId, d.planName, d.planPrice, d.planInterval);
          });
        },

        openModal(planId, planName, price, interval) {
          this.selectedPlanId = planId;
          this.selectedPlanName = planName;
          this.selectedPlanPrice = price;
          this.selectedPlanInterval = interval;
          this.selectedGateway = this.gateways.length > 0 ? this.gateways[0].id : '';
          this.tocConsent = false;
          this.showPaymentModal = true;
        },

        proceedToPayment() {
          if (!this.tocConsent || !this.selectedGateway) return;
          const gateway = this.gateways.find(g => g.id === this.selectedGateway);
          if (gateway && gateway.paymentLink) {
            window.open(gateway.paymentLink, '_blank', 'noopener');
            this.showPaymentModal = false;
          }
        },
      };
    }
  </script>
</BaseLayout>
