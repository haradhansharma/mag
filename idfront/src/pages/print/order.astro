---
// print/order.astro
// Print-on-Demand order page with:
// - WeekSelector (Alpine.js calendar/edition picker)
// - PrintPreview (iframe or visual preview)
// - OrderForm (quantity +/-, address fields, price calculation)
// Wrapped in BaseLayout for consistent site navigation.

import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/common/Breadcrumbs.astro';
import NewsletterSignup from '@components/common/NewsletterSignup.astro';
import { getAllEditions } from '@data/service';
import { formatEditionDateRange } from '@utils/helpers';

const allEditions = await getAllEditions();
const printReadyEditions = allEditions.filter(e => e.printReady);

// Serialize edition data for Alpine.js (client-side script can't use Astro expressions)
const editionsJson = JSON.stringify(printReadyEditions.map(e => ({
  id: e.id,
  number: e.number,
  title: e.title,
  subtitle: e.subtitle,
  slug: e.slug,
  dateRange: formatEditionDateRange(e.weekStart, e.weekEnd),
  articleCount: e.articleCount,
  printReady: e.printReady,
})));
---

<BaseLayout
  title="Order Print Edition — MERIDIAN Magazine"
  description="Order a premium print copy of MERIDIAN magazine. Select your edition, customize your order, and get it delivered to your door."
  canonicalUrl="/print/order"
>
  <div class="bg-surface dark:bg-primary min-h-screen">
    <!-- Breadcrumbs -->
    <div class="max-w-6xl mx-auto px-4 pt-6">
      <Breadcrumbs
        items={[
          { label: 'Home', href: '/' },
          { label: 'Print Editions', href: '/print/order' },
          { label: 'Order' },
        ]}
      />
    </div>

    <!-- Hero Header -->
    <section class="bg-gradient-to-br from-primary via-secondary to-primary py-16 sm:py-20">
      <div class="max-w-6xl mx-auto px-4 text-center">
        <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm rounded-full px-4 py-1.5 mb-6">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#38BDF8" stroke-width="2">
            <polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 01-2-2v-5a2 2 0 012-2h16a2 2 0 012 2v5a2 2 0 01-2 2h-2"/><rect x="6" y="14" width="12" height="8"/>
          </svg>
          <span class="text-sm text-accent-light font-medium">Print-on-Demand</span>
        </div>
        <h1 class="font-editorial text-4xl sm:text-5xl font-bold text-white mb-4">
          Order Your Print Edition
        </h1>
        <p class="text-gray-400 max-w-2xl mx-auto text-lg">
          Experience MERIDIAN in its purest form. Premium paper, museum-quality printing, delivered to your doorstep within 5–7 business days.
        </p>
      </div>
    </section>

    <!-- Main Content: 3-column layout -->
    <div
      x-data={`printOrder(${editionsJson})`}
      class="max-w-6xl mx-auto px-4 py-12"
    >
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

        <!-- Left: Week Selector + Edition Preview -->
        <div class="lg:col-span-1 space-y-6">

          <!-- Week / Edition Selector -->
          <div class="bg-white dark:bg-gray-900 rounded-xl border border-border dark:border-gray-700 p-6">
            <h3 class="font-editorial text-xl font-bold text-primary dark:text-white mb-4">
              Select Edition
            </h3>

            <!-- Edition Dropdown -->
            <div class="space-y-3">
              <label class="block text-sm font-medium text-text-secondary dark:text-gray-400">
                Choose an edition
              </label>
              <select
                x-model="selectedEditionId"
                @change="onEditionChange()"
                class="w-full rounded-lg border border-border dark:border-gray-600 bg-surface dark:bg-gray-800 text-primary dark:text-white px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-accent"
              >
                <option value="">— Select an edition —</option>
                <template x-for="edition in editions" :key="edition.id">
                  <option :value="edition.id" x-text="`Edition #${edition.number}: ${edition.title}`"></option>
                </template>
              </select>
            </div>

            <!-- Selected Edition Info -->
            <div x-show="selectedEdition" x-transition class="mt-5 space-y-3">
              <div class="bg-surface-alt dark:bg-gray-800 rounded-lg p-4">
                <div class="flex items-center gap-2 mb-2">
                  <span class="inline-block px-2 py-0.5 bg-accent/10 text-accent text-xs font-semibold rounded">
                    Edition #<span x-text="selectedEdition.number"></span>
                  </span>
                  <span x-show="selectedEdition.printReady" class="inline-block px-2 py-0.5 bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400 text-xs font-semibold rounded">
                    Print Ready
                  </span>
                </div>
                <h4 class="font-editorial font-bold text-primary dark:text-white text-base" x-text="selectedEdition.title"></h4>
                <p class="text-sm text-text-muted dark:text-gray-500 mt-1" x-text="selectedEdition.subtitle"></p>
                <div class="flex items-center gap-3 mt-3 text-xs text-text-secondary dark:text-gray-400">
                  <span class="flex items-center gap-1">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    <span x-text="selectedEdition.dateRange"></span>
                  </span>
                  <span class="flex items-center gap-1">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                    <span x-text="`${selectedEdition.articleCount} articles`"></span>
                  </span>
                </div>
              </div>

              <!-- Print Preview Link -->
              <a
                x-show="selectedEdition.printReady"
                :href="`/print/${selectedEdition.slug}`"
                class="block w-full text-center bg-accent/10 hover:bg-accent/20 text-accent font-medium py-2.5 rounded-lg text-sm transition-colors"
              >
                View Print Preview →
              </a>
            </div>
          </div>

          <!-- Pricing Info Card -->
          <div class="bg-white dark:bg-gray-900 rounded-xl border border-border dark:border-gray-700 p-6">
            <h3 class="font-editorial text-lg font-bold text-primary dark:text-white mb-3">
              Pricing
            </h3>
            <div class="space-y-3">
              <div class="flex justify-between items-center text-sm">
                <span class="text-text-secondary dark:text-gray-400">Single Copy</span>
                <span class="font-semibold text-primary dark:text-white">$12.99</span>
              </div>
              <div class="flex justify-between items-center text-sm">
                <span class="text-text-secondary dark:text-gray-400">2+ Copies (each)</span>
                <span class="font-semibold text-primary dark:text-white">$10.99</span>
              </div>
              <div class="flex justify-between items-center text-sm">
                <span class="text-text-secondary dark:text-gray-400">5+ Copies (each)</span>
                <span class="font-semibold text-primary dark:text-white">$9.49</span>
              </div>
              <hr class="border-border dark:border-gray-700" />
              <div class="flex justify-between items-center text-sm">
                <span class="text-text-secondary dark:text-gray-400">Shipping (US)</span>
                <span class="font-semibold text-primary dark:text-white">$4.99</span>
              </div>
              <div class="flex justify-between items-center text-sm">
                <span class="text-text-secondary dark:text-gray-400">Shipping (International)</span>
                <span class="font-semibold text-primary dark:text-white">$9.99</span>
              </div>
            </div>
            <div class="mt-4 bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-lg p-3 text-xs text-amber-700 dark:text-amber-400">
              <div class="flex items-start gap-2">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="mt-0.5 shrink-0"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                <span>Volume discounts apply automatically. Free shipping on orders over $50. All prices in USD.</span>
              </div>
            </div>
          </div>

          <!-- Print Specs -->
          <div class="bg-white dark:bg-gray-900 rounded-xl border border-border dark:border-gray-700 p-6">
            <h3 class="font-editorial text-lg font-bold text-primary dark:text-white mb-3">
              Print Specifications
            </h3>
            <div class="grid grid-cols-2 gap-3 text-sm">
              <div class="bg-surface-alt dark:bg-gray-800 rounded-lg p-3 text-center">
                <div class="text-text-muted dark:text-gray-500 text-xs mb-1">Format</div>
                <div class="font-semibold text-primary dark:text-white">A4</div>
              </div>
              <div class="bg-surface-alt dark:bg-gray-800 rounded-lg p-3 text-center">
                <div class="text-text-muted dark:text-gray-500 text-xs mb-1">Paper</div>
                <div class="font-semibold text-primary dark:text-white">170gsm</div>
              </div>
              <div class="bg-surface-alt dark:bg-gray-800 rounded-lg p-3 text-center">
                <div class="text-text-muted dark:text-gray-500 text-xs mb-1">Resolution</div>
                <div class="font-semibold text-primary dark:text-white">300 DPI</div>
              </div>
              <div class="bg-surface-alt dark:bg-gray-800 rounded-lg p-3 text-center">
                <div class="text-text-muted dark:text-gray-500 text-xs mb-1">Color</div>
                <div class="font-semibold text-primary dark:text-white">CMYK</div>
              </div>
              <div class="bg-surface-alt dark:bg-gray-800 rounded-lg p-3 text-center">
                <div class="text-text-muted dark:text-gray-500 text-xs mb-1">Binding</div>
                <div class="font-semibold text-primary dark:text-white">Saddle</div>
              </div>
              <div class="bg-surface-alt dark:bg-gray-800 rounded-lg p-3 text-center">
                <div class="text-text-muted dark:text-gray-500 text-xs mb-1">Pages</div>
                <div class="font-semibold text-primary dark:text-white">24–36</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Center + Right: Order Form -->
        <div class="lg:col-span-2 space-y-6">

          <!-- Cover Preview -->
          <div class="bg-white dark:bg-gray-900 rounded-xl border border-border dark:border-gray-700 overflow-hidden">
            <div class="p-4 border-b border-border dark:border-gray-700 flex items-center justify-between">
              <h3 class="font-editorial text-lg font-bold text-primary dark:text-white">
                Cover Preview
              </h3>
              <span x-show="selectedEdition" class="text-xs text-text-muted dark:text-gray-500">
                <span x-text="selectedEdition ? `Edition #${selectedEdition.number}` : ''"></span>
              </span>
            </div>
            <div class="p-6 flex items-center justify-center min-h-[400px] bg-surface-alt dark:bg-gray-800">
              <!-- No edition selected state -->
              <div x-show="!selectedEdition" class="text-center">
                <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#94A3B8" stroke-width="1" class="mx-auto mb-4">
                  <path d="M4 19.5A2.5 2.5 0 016.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/>
                </svg>
                <p class="text-text-muted dark:text-gray-500 text-sm">Select an edition to preview its cover</p>
              </div>

              <!-- Edition selected — simulated cover -->
              <div
                x-show="selectedEdition"
                x-transition
                class="w-full max-w-sm"
              >
                <div class="aspect-[3/4] bg-gradient-to-b from-primary to-secondary rounded-lg shadow-xl overflow-hidden relative">
                  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-primary/90"></div>
                  <div class="absolute bottom-0 left-0 right-0 p-6">
                    <div class="text-accent text-[10px] font-semibold tracking-widest uppercase mb-2">
                      Edition #<span x-text="selectedEdition.number"></span>
                    </div>
                    <h4 class="font-editorial text-2xl font-bold text-white leading-tight mb-2" x-text="selectedEdition.title"></h4>
                    <p class="text-gray-400 text-xs leading-relaxed" x-text="selectedEdition.subtitle"></p>
                    <div class="mt-3 h-px w-12 bg-accent"></div>
                  </div>
                  <!-- Decorative top bar -->
                  <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-accent via-accent-light to-accent-warm"></div>
                </div>
              </div>
            </div>
          </div>

          <!-- Order Form -->
          <div class="bg-white dark:bg-gray-900 rounded-xl border border-border dark:border-gray-700 p-6 sm:p-8">
            <h3 class="font-editorial text-xl font-bold text-primary dark:text-white mb-6">
              Place Your Order
            </h3>

            <form @submit.prevent="submitOrder()" class="space-y-6">

              <!-- Quantity Selector -->
              <div>
                <label class="block text-sm font-medium text-text-secondary dark:text-gray-400 mb-2">
                  Quantity
                </label>
                <div class="flex items-center gap-4">
                  <button
                    type="button"
                    @click="decrementQty()"
                    :disabled="quantity <= 1"
                    aria-label="Decrease quantity"
                    class="w-10 h-10 rounded-lg border border-border dark:border-gray-600 flex items-center justify-center text-primary dark:text-white hover:bg-surface-alt dark:hover:bg-gray-800 disabled:opacity-40 disabled:cursor-not-allowed transition-colors"
                  >
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/></svg>
                  </button>
                  <input
                    type="number"
                    x-model.number="quantity"
                    @input="calculateTotal()"
                    min="1"
                    max="99"
                    class="w-20 text-center rounded-lg border border-border dark:border-gray-600 bg-surface dark:bg-gray-800 text-primary dark:text-white py-2.5 text-lg font-semibold focus:outline-none focus:ring-2 focus:ring-accent"
                  />
                  <button
                    type="button"
                    @click="incrementQty()"
                    :disabled="quantity >= 99"
                    aria-label="Increase quantity"
                    class="w-10 h-10 rounded-lg border border-border dark:border-gray-600 flex items-center justify-center text-primary dark:text-white hover:bg-surface-alt dark:hover:bg-gray-800 disabled:opacity-40 disabled:cursor-not-allowed transition-colors"
                  >
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                  </button>
                  <div class="text-sm text-text-muted dark:text-gray-500">
                    <span x-show="quantity >= 5" class="text-green-600 dark:text-green-400 font-medium">
                      Bulk price applied!
                    </span>
                    <span x-show="quantity >= 2 && quantity < 5" class="text-accent font-medium">
                      Multi-copy discount applied
                    </span>
                    <span x-show="quantity === 1">
                      Volume discounts at 2+ copies
                    </span>
                  </div>
                </div>
              </div>

              <!-- Shipping Region -->
              <div>
                <label class="block text-sm font-medium text-text-secondary dark:text-gray-400 mb-2">
                  Shipping Region
                </label>
                <select
                  x-model="shippingRegion"
                  @change="calculateTotal()"
                  class="w-full rounded-lg border border-border dark:border-gray-600 bg-surface dark:bg-gray-800 text-primary dark:text-white px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-accent"
                >
                  <option value="us">United States ($4.99)</option>
                  <option value="international">International ($9.99)</option>
                </select>
              </div>

              <!-- Delivery Address -->
              <div class="space-y-4">
                <h4 class="text-sm font-semibold text-primary dark:text-white">
                  Delivery Address
                </h4>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  <div>
                    <label class="block text-xs text-text-muted dark:text-gray-500 mb-1">First Name *</label>
                    <input
                      type="text"
                      x-model="address.firstName"
                      required
                      placeholder="John"
                      class="w-full rounded-lg border border-border dark:border-gray-600 bg-surface dark:bg-gray-800 text-primary dark:text-white px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-accent"
                    />
                  </div>
                  <div>
                    <label class="block text-xs text-text-muted dark:text-gray-500 mb-1">Last Name *</label>
                    <input
                      type="text"
                      x-model="address.lastName"
                      required
                      placeholder="Doe"
                      class="w-full rounded-lg border border-border dark:border-gray-600 bg-surface dark:bg-gray-800 text-primary dark:text-white px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-accent"
                    />
                  </div>
                </div>
                <div>
                  <label class="block text-xs text-text-muted dark:text-gray-500 mb-1">Street Address *</label>
                  <input
                    type="text"
                    x-model="address.street"
                    required
                    placeholder="123 Magazine Lane"
                    class="w-full rounded-lg border border-border dark:border-gray-600 bg-surface dark:bg-gray-800 text-primary dark:text-white px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-accent"
                  />
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                  <div>
                    <label class="block text-xs text-text-muted dark:text-gray-500 mb-1">City *</label>
                    <input
                      type="text"
                      x-model="address.city"
                      required
                      placeholder="New York"
                      class="w-full rounded-lg border border-border dark:border-gray-600 bg-surface dark:bg-gray-800 text-primary dark:text-white px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-accent"
                    />
                  </div>
                  <div>
                    <label class="block text-xs text-text-muted dark:text-gray-500 mb-1">State *</label>
                    <input
                      type="text"
                      x-model="address.state"
                      required
                      placeholder="NY"
                      class="w-full rounded-lg border border-border dark:border-gray-600 bg-surface dark:bg-gray-800 text-primary dark:text-white px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-accent"
                    />
                  </div>
                  <div>
                    <label class="block text-xs text-text-muted dark:text-gray-500 mb-1">ZIP Code *</label>
                    <input
                      type="text"
                      x-model="address.zip"
                      required
                      placeholder="10001"
                      class="w-full rounded-lg border border-border dark:border-gray-600 bg-surface dark:bg-gray-800 text-primary dark:text-white px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-accent"
                    />
                  </div>
                </div>
              </div>

              <!-- Order Summary -->
              <div class="bg-surface-alt dark:bg-gray-800 rounded-xl p-5 space-y-3">
                <h4 class="text-sm font-semibold text-primary dark:text-white mb-3">Order Summary</h4>
                <div class="flex justify-between text-sm">
                  <span class="text-text-secondary dark:text-gray-400">
                    <span x-text="quantity"></span> × <span x-text="unitPriceLabel"></span>
                  </span>
                  <span class="text-primary dark:text-white font-medium" x-text="`$${subtotal.toFixed(2)}`"></span>
                </div>
                <div class="flex justify-between text-sm">
                  <span class="text-text-secondary dark:text-gray-400">Shipping (<span x-text="shippingRegion === 'us' ? 'US' : 'International'"></span>)</span>
                  <span class="text-primary dark:text-white font-medium" x-text="shippingCost === 0 ? 'FREE' : `$${shippingCost.toFixed(2)}`"></span>
                </div>
                <div x-show="discount > 0" class="flex justify-between text-sm">
                  <span class="text-green-600 dark:text-green-400">Volume Discount</span>
                  <span class="text-green-600 dark:text-green-400 font-medium" x-text="`-$${discount.toFixed(2)}`"></span>
                </div>
                <hr class="border-border dark:border-gray-700" />
                <div class="flex justify-between text-base">
                  <span class="font-bold text-primary dark:text-white">Total</span>
                  <span class="font-bold text-accent text-xl" x-text="`$${total.toFixed(2)}`"></span>
                </div>
                <p x-show="shippingCost === 0" class="text-xs text-green-600 dark:text-green-400 text-center">
                  🎉 You qualify for free shipping!
                </p>
              </div>

              <!-- Submit Button -->
              <button
                type="submit"
                :disabled="!canSubmit()"
                class="w-full bg-accent hover:bg-accent-dark disabled:bg-gray-300 dark:disabled:bg-gray-700 disabled:cursor-not-allowed text-white font-semibold py-3.5 rounded-xl text-sm transition-colors flex items-center justify-center gap-2"
              >
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
                <span x-text="submitting ? 'Placing Order...' : 'Place Order'"></span>
              </button>

              <!-- Success Message -->
              <div
                x-show="orderPlaced"
                x-transition
                role="status"
                aria-live="polite"
                class="bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-xl p-5 text-center"
              >
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#059669" stroke-width="2" class="mx-auto mb-3">
                  <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
                </svg>
                <h4 class="font-semibold text-green-700 dark:text-green-400 text-lg mb-1">Order Placed Successfully!</h4>
                <p class="text-sm text-green-600 dark:text-green-500">
                  Your print order has been received. You'll receive a confirmation email shortly with tracking information.
                </p>
                <p class="text-xs text-green-500 dark:text-green-600 mt-2">
                  Order ID: <span class="font-mono" x-text="orderId"></span>
                </p>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>

    <!-- Newsletter CTA -->
    <NewsletterSignup variant="section" />
  </div>
</BaseLayout>

<!-- Alpine.js Print Order Component -->
<script is:inline>
function printOrder(editionsData) {
  return {
    editions: editionsData || [],

    selectedEditionId: '',
    selectedEdition: null,
    quantity: 1,
    shippingRegion: 'us',
    submitting: false,
    orderPlaced: false,
    orderId: '',

    address: {
      firstName: '',
      lastName: '',
      street: '',
      city: '',
      state: '',
      zip: '',
    },

    get unitPrice() {
      if (this.quantity >= 5) return 9.49;
      if (this.quantity >= 2) return 10.99;
      return 12.99;
    },

    get unitPriceLabel() {
      return `$${this.unitPrice.toFixed(2)} each`;
    },

    get subtotal() {
      return this.unitPrice * this.quantity;
    },

    get shippingCost() {
      const base = this.shippingRegion === 'us' ? 4.99 : 9.99;
      if (this.subtotal >= 50) return 0;
      return base;
    },

    get discount() {
      const fullPrice = 12.99 * this.quantity;
      return Math.max(0, fullPrice - this.subtotal);
    },

    get total() {
      return this.subtotal + this.shippingCost - this.discount;
    },

    onEditionChange() {
      this.selectedEdition = this.editions.find(e => e.id === this.selectedEditionId) || null;
    },

    incrementQty() {
      if (this.quantity < 99) {
        this.quantity++;
        this.calculateTotal();
      }
    },

    decrementQty() {
      if (this.quantity > 1) {
        this.quantity--;
        this.calculateTotal();
      }
    },

    calculateTotal() {
      // Computed properties auto-update
    },

    canSubmit() {
      return this.selectedEditionId &&
        this.address.firstName.trim() &&
        this.address.lastName.trim() &&
        this.address.street.trim() &&
        this.address.city.trim() &&
        this.address.state.trim() &&
        this.address.zip.trim() &&
        !this.submitting &&
        !this.orderPlaced;
    },

    async submitOrder() {
      if (!this.canSubmit()) return;
      this.submitting = true;
      this.orderId = 'MRD-' + Date.now().toString(36).toUpperCase() + '-' + Math.random().toString(36).substring(2, 6).toUpperCase();

      // Simulate API call
      await new Promise(resolve => setTimeout(resolve, 1500));

      this.submitting = false;
      this.orderPlaced = true;
    },
  };
}
</script>
