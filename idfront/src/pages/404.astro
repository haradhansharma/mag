---
// 404 Not Found Page
// Custom error page with search and navigation links.
import BaseLayout from '@layouts/BaseLayout.astro';
import NewsletterSignup from '@components/common/NewsletterSignup.astro';
---

<BaseLayout title="Page Not Found — MERIDIAN" description="The page you're looking for doesn't exist.">
  <div class="page-transition">
    <section class="py-24 sm:py-32">
      <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <!-- 404 Number -->
        <div class="mb-6">
          <span class="font-editorial text-8xl sm:text-9xl font-bold text-accent/10 select-none">404</span>
        </div>

        <!-- Error Icon -->
        <div class="w-20 h-20 mx-auto mb-6 rounded-full bg-surface dark:bg-gray-800 flex items-center justify-center border border-border dark:border-gray-700">
          <svg class="w-10 h-10 text-text-muted dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>

        <h1 class="font-editorial text-3xl sm:text-4xl font-bold mb-4">
          Page Not Found
        </h1>
        <p class="text-text-secondary dark:text-gray-400 text-lg mb-8 max-w-lg mx-auto">
          The page you're looking for doesn't exist or has been moved. Let's get you back on track.
        </p>

        <!-- Action Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="/"
            class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-accent hover:bg-sky-600 text-white font-semibold rounded-lg transition-colors"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
            Back to Homepage
          </a>
          <a
            href="/search"
            class="inline-flex items-center justify-center gap-2 px-6 py-3 border border-border dark:border-gray-600 text-text-secondary dark:text-gray-400 hover:bg-surface-alt dark:hover:bg-gray-800 font-semibold rounded-lg transition-colors"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            Search Articles
          </a>
        </div>

        <!-- Quick Links -->
        <div class="mt-16 grid grid-cols-2 sm:grid-cols-4 gap-4">
          <a href="/editions/archive" class="block p-4 bg-surface dark:bg-gray-900 rounded-xl border border-border dark:border-gray-800 hover:border-accent/30 transition-colors group">
            <p class="font-editorial font-bold text-sm group-hover:text-accent transition-colors">Editions</p>
            <p class="text-xs text-text-muted dark:text-gray-500 mt-1">Browse archive</p>
          </a>
          <a href="/categories/science-tech" class="block p-4 bg-surface dark:bg-gray-900 rounded-xl border border-border dark:border-gray-800 hover:border-accent/30 transition-colors group">
            <p class="font-editorial font-bold text-sm group-hover:text-accent transition-colors">Science</p>
            <p class="text-xs text-text-muted dark:text-gray-500 mt-1">Latest research</p>
          </a>
          <a href="/subscribe" class="block p-4 bg-surface dark:bg-gray-900 rounded-xl border border-border dark:border-gray-800 hover:border-accent/30 transition-colors group">
            <p class="font-editorial font-bold text-sm group-hover:text-accent transition-colors">Subscribe</p>
            <p class="text-xs text-text-muted dark:text-gray-500 mt-1">Join premium</p>
          </a>
          <a href="/about" class="block p-4 bg-surface dark:bg-gray-900 rounded-xl border border-border dark:border-gray-800 hover:border-accent/30 transition-colors group">
            <p class="font-editorial font-bold text-sm group-hover:text-accent transition-colors">About</p>
            <p class="text-xs text-text-muted dark:text-gray-500 mt-1">Our mission</p>
          </a>
        </div>
      </div>
    </section>

    <NewsletterSignup variant="inline" />
  </div>
</BaseLayout>
