---
/**
 * Author Page — /authors/[slug]
 * Dynamic route displaying an author's profile and their articles.
 * Uses getStaticPaths() for static generation of all author pages.
 */

import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/common/Breadcrumbs.astro';
import ArticleCard from '@components/common/ArticleCard.astro';
import { getAllAuthors, getAuthorBySlug, getArticlesByAuthorId } from '../../data/service.ts';
import { getInitials } from '@utils/helpers';

// ==================== Static Paths ====================
export async function getStaticPaths() {
  const authors = await getAllAuthors();
  return authors.map((author) => ({
    params: { slug: author.slug },
  }));
}

// ==================== Page Data ====================
const { slug } = Astro.params;
const author = await getAuthorBySlug(slug!);

// 404 fallback — redirect if author not found
if (!author) {
  return Astro.redirect('/404');
}

// Get author's articles
const articles = await getArticlesByAuthorId(author.id);
const initials = getInitials(author.name);

// SEO
const title = `${author.name} — MERIDIAN Author`;
const description = `${author.role} at MERIDIAN. ${author.articleCount} published articles. ${author.bio}`;
---

<BaseLayout title={title} description={description} canonicalUrl={`/authors/${author.slug}`}>
  <div class="page-transition">

    <!-- ==================== Breadcrumbs ==================== -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-6">
      <Breadcrumbs items={[
        { label: 'Home', href: '/' },
        { label: 'Authors' },
        { label: author.name },
      ]} />
    </div>

    <!-- ==================== Author Profile Header ==================== -->
    <section class="py-12 bg-white dark:bg-gray-950 border-b border-border dark:border-gray-800">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col sm:flex-row items-start gap-6">
          <!-- Avatar -->
          <div class="w-24 h-24 rounded-full bg-gradient-to-br from-accent to-blue-700 flex items-center justify-center text-white text-3xl font-bold flex-shrink-0">
            {initials}
          </div>

          <!-- Info -->
          <div class="flex-1 min-w-0">
            <h1 class="font-editorial text-3xl font-bold mb-1">
              {author.name}
            </h1>
            <p class="text-accent font-semibold mb-3">{author.role}</p>
            <p class="text-text-secondary dark:text-gray-400 max-w-2xl leading-relaxed mb-4">
              {author.bio}
            </p>

            <!-- Social links + article count -->
            <div class="flex flex-wrap items-center gap-4">
              {/* Article count badge */}
              <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-surface dark:bg-gray-800 rounded-full text-sm text-text-secondary dark:text-gray-400 border border-border dark:border-gray-700">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
                </svg>
                {articles.length} articles published
              </span>

              {/* Social links */}
              {author.socials?.twitter && (
                <a
                  href={author.socials.twitter}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1.5 px-3 py-1 bg-surface dark:bg-gray-800 rounded-full text-sm text-text-muted dark:text-gray-500 hover:text-accent dark:hover:text-accent-light border border-border dark:border-gray-700 transition-colors"
                  title="Twitter / X"
                >
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                  Twitter
                </a>
              )}

              {author.socials?.linkedin && (
                <a
                  href={author.socials.linkedin}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1.5 px-3 py-1 bg-surface dark:bg-gray-800 rounded-full text-sm text-text-muted dark:text-gray-500 hover:text-accent dark:hover:text-accent-light border border-border dark:border-gray-700 transition-colors"
                  title="LinkedIn"
                >
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                  LinkedIn
                </a>
              )}

              {author.socials?.instagram && (
                <a
                  href={author.socials.instagram}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1.5 px-3 py-1 bg-surface dark:bg-gray-800 rounded-full text-sm text-text-muted dark:text-gray-500 hover:text-accent dark:hover:text-accent-light border border-border dark:border-gray-700 transition-colors"
                  title="Instagram"
                >
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
                  Instagram
                </a>
              )}

              {author.socials?.website && (
                <a
                  href={author.socials.website}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1.5 px-3 py-1 bg-surface dark:bg-gray-800 rounded-full text-sm text-text-muted dark:text-gray-500 hover:text-accent dark:hover:text-accent-light border border-border dark:border-gray-700 transition-colors"
                  title="Website"
                >
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>
                  Website
                </a>
              )}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ==================== Articles Grid ==================== -->
    <section class="py-12 bg-surface dark:bg-gray-900">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="font-editorial text-2xl font-bold mb-8">
          Articles by {author.name}
        </h2>

        {articles.length > 0 ? (
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {articles.map((article) => (
              <ArticleCard article={article} variant="grid" />
            ))}
          </div>
        ) : (
          <div class="text-center py-16">
            <div class="w-16 h-16 rounded-full bg-white dark:bg-gray-800 flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-text-muted dark:text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
              </svg>
            </div>
            <p class="text-text-secondary dark:text-gray-400">
              No articles published yet by this author.
            </p>
          </div>
        )}
      </div>
    </section>

  </div>
</BaseLayout>
