---
// ============================================================
// MERIDIAN Magazine — Edition Detail Page
// ============================================================
// Dynamic route: /editions/{slug}
// Displays a single weekly edition with full-bleed hero header,
// category-grouped table of contents, sidebar, and newsletter.
// ============================================================

import EditionLayout from '@layouts/EditionLayout.astro';
import Breadcrumbs from '@components/common/Breadcrumbs.astro';
import NewsletterSignup from '@components/common/NewsletterSignup.astro';
import { getAllEditions, getEditionBySlug } from '@data/service';
import { formatEditionDateRange, getInitials } from '@utils/helpers';
import type { Article } from '@data/types';

// --- Static paths for all published editions ---
export async function getStaticPaths() {
  const editions = await getAllEditions();
  return editions.map((edition) => ({
    params: { slug: edition.slug },
  }));
}

// --- Fetch edition data ---
const { slug } = Astro.params;
const edition = await getEditionBySlug(slug!);

// Redirect to 404 if edition not found
if (!edition) {
  return Astro.redirect('/404');
}

// --- Computed values ---
const dateRange = formatEditionDateRange(edition.weekStart, edition.weekEnd);
const editionArticles = edition.articles || [];
const articleCount = editionArticles.length;

// --- Group articles by category ---
const categoryGroups: { categoryName: string; categorySlug: string; articles: Article[] }[] = [];
const seenCategories = new Set<string>();
for (const article of editionArticles) {
  const catName = article.category?.name || 'Uncategorized';
  const catSlug = article.category?.slug || '';
  if (!seenCategories.has(catName)) {
    seenCategories.add(catName);
    categoryGroups.push({ categoryName: catName, categorySlug: catSlug, articles: [] });
  }
  const group = categoryGroups.find(g => g.categoryName === catName)!;
  group.articles.push(article);
}

// --- Category color mapping for TOC section headers ---
const categoryColorMap: Record<string, { header: string; dot: string; number: string; hover: string }> = {
  'Science & Tech':   { header: 'text-blue-500',    dot: 'bg-blue-500',    number: 'text-blue-500/30',    hover: 'hover:bg-blue-50 dark:hover:bg-blue-950/30' },
  'World News':       { header: 'text-rose-500',    dot: 'bg-rose-500',    number: 'text-rose-500/30',    hover: 'hover:bg-rose-50 dark:hover:bg-rose-950/30' },
  'Environment':      { header: 'text-green-600',   dot: 'bg-green-600',   number: 'text-green-600/30',   hover: 'hover:bg-green-50 dark:hover:bg-green-950/30' },
  'Culture':          { header: 'text-purple-600',  dot: 'bg-purple-600',  number: 'text-purple-600/30',  hover: 'hover:bg-purple-50 dark:hover:bg-purple-950/30' },
  'Health':           { header: 'text-teal-600',    dot: 'bg-teal-600',    number: 'text-teal-600/30',    hover: 'hover:bg-teal-50 dark:hover:bg-teal-950/30' },
  'Sports':           { header: 'text-orange-500',  dot: 'bg-orange-500',  number: 'text-orange-500/30',  hover: 'hover:bg-orange-50 dark:hover:bg-orange-950/30' },
  'Business & Economy': { header: 'text-amber-500', dot: 'bg-amber-500',   number: 'text-amber-500/30',   hover: 'hover:bg-amber-50 dark:hover:bg-amber-950/30' },
  'Opinion & Analysis': { header: 'text-indigo-600', dot: 'bg-indigo-600', number: 'text-indigo-600/30',  hover: 'hover:bg-indigo-50 dark:hover:bg-indigo-950/30' },
  'Deep Dives':       { header: 'text-cyan-600',    dot: 'bg-cyan-600',    number: 'text-cyan-600/30',    hover: 'hover:bg-cyan-50 dark:hover:bg-cyan-950/30' },
  'Future Forward':   { header: 'text-pink-600',    dot: 'bg-pink-600',    number: 'text-pink-600/30',    hover: 'hover:bg-pink-50 dark:hover:bg-pink-950/30' },
  'Lifestyle & Travel': { header: 'text-emerald-600', dot: 'bg-emerald-600', number: 'text-emerald-600/30', hover: 'hover:bg-emerald-50 dark:hover:bg-emerald-950/30' },
};

function getCategoryColors(name: string) {
  return categoryColorMap[name] || { header: 'text-accent', dot: 'bg-accent', number: 'text-accent/30', hover: 'hover:bg-surface' };
}

// --- Global article number counter across all groups ---
let globalArticleNum = 0;

// --- Get other editions for sidebar (exclude current, up to 3) ---
const allEditions = await getAllEditions();
const otherEditions = allEditions
  .filter(e => e.id !== edition.id)
  .sort((a, b) => b.number - a.number)
  .slice(0, 3);

// --- Breadcrumb items ---
const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Editions', href: '/editions/archive' },
  { label: `Edition #${edition.number}` },
];
---

<EditionLayout edition={edition}>

  <!-- ====== Breadcrumbs ====== -->
  <div class="bg-primary dark:bg-primary">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-6 pb-2">
      <Breadcrumbs items={breadcrumbs} />
    </div>
  </div>

  <!-- ====== Edition Hero Header ====== -->
  <section class="relative h-[50vh] min-h-[400px] overflow-hidden">
    <!-- Cover image -->
    <img
      src={edition.coverImage}
      alt={`Edition #${edition.number}: ${edition.title}`}
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
    <!-- Gradient overlay -->
    <div class="absolute inset-0 bg-gradient-to-t from-primary via-primary/70 to-primary/30"></div>

    <!-- Content overlay -->
    <div class="absolute inset-0 flex flex-col justify-end">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full pb-12 sm:pb-16">
        <!-- Edition badge + date range pill -->
        <div class="flex flex-wrap items-center gap-3 mb-5">
          <span class="inline-flex items-center px-3 py-1 rounded-full bg-accent-warm text-white text-xs font-bold uppercase tracking-wide">
            Edition #{edition.number}
          </span>
          <span class="inline-flex items-center px-3 py-1 rounded-full bg-white/10 backdrop-blur-sm text-white/80 text-xs font-medium">
            {dateRange}
          </span>
        </div>

        <!-- Title -->
        <h1 class="font-editorial text-3xl sm:text-5xl font-bold text-white mb-3 max-w-3xl leading-tight">
          {edition.title}
        </h1>

        <!-- Subtitle -->
        {edition.subtitle && (
          <p class="text-gray-300 text-lg max-w-2xl mb-5">
            {edition.subtitle}
          </p>
        )}

        <!-- Article count info line -->
        <div class="flex items-center gap-2 text-sm text-gray-400">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
          </svg>
          <span>{articleCount} {articleCount === 1 ? 'article' : 'articles'} in this edition</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== Table of Contents ====== -->
  <section class="bg-white dark:bg-primary py-12 sm:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Section header -->
      <div class="mb-10">
        <h2 class="font-editorial text-2xl sm:text-3xl font-bold text-text-primary dark:text-gray-100 mb-2">
          In This Edition
        </h2>
        <p class="text-text-muted dark:text-gray-500 text-sm">
          Browse all articles from Edition #{edition.number}, organized by category.
        </p>
      </div>

      <!-- 2-column layout: main TOC + sidebar -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">

        <!-- ====== Main TOC (left 2/3) ====== -->
        <div class="lg:col-span-2">
          {categoryGroups.length > 0 ? (
            <div class="space-y-8">
              {categoryGroups.map((group) => {
                const colors = getCategoryColors(group.categoryName);
                return (
                  <div>
                    <!-- Category section header -->
                    <div class="flex items-center gap-2.5 mb-4">
                      <span class={`w-2.5 h-2.5 rounded-full ${colors.dot}`}></span>
                      <h3 class={`text-xs font-bold ${colors.header} uppercase tracking-wider`}>
                        {group.categoryName}
                      </h3>
                      <span class="text-text-muted dark:text-gray-600 text-xs">— {group.articles.length} {group.articles.length === 1 ? 'article' : 'articles'}</span>
                    </div>

                    <!-- Article list -->
                    <div class="space-y-1">
                      {group.articles.map((article) => {
                        globalArticleNum++;
                        const num = globalArticleNum;
                        const isPremium = article.access === 'premium';
                        const initials = article.author ? getInitials(article.author.name) : '';
                        return (
                          <a
                            href={`/articles/${article.slug}`}
                            class={`flex items-start gap-4 p-4 rounded-xl transition-colors ${colors.hover}`}
                          >
                            <!-- Article number -->
                            <span class={`text-2xl font-editorial font-bold ${colors.number} min-w-[2rem] text-right pt-0.5`}>
                              {String(num).padStart(2, '0')}
                            </span>

                            <!-- Article content -->
                            <div class="flex-1 min-w-0">
                              <!-- Title row with premium indicator -->
                              <div class="flex items-start gap-2">
                                <h4 class="text-base font-semibold text-text-primary dark:text-gray-100 leading-snug line-clamp-2 hover:text-accent transition-colors">
                                  {article.title}
                                </h4>
                                {isPremium && (
                                  <svg class="w-4 h-4 text-accent-warm flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20" aria-label="Premium article">
                                    <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd" />
                                  </svg>
                                )}
                              </div>

                              <!-- Author + reading time -->
                              <div class="flex items-center gap-3 mt-1.5 text-sm text-text-muted dark:text-gray-500">
                                {article.author && (
                                  <span class="flex items-center gap-1.5">
                                    <span class="w-5 h-5 rounded-full bg-gradient-to-br from-accent to-blue-700 text-white text-[10px] font-bold flex items-center justify-center">
                                      {initials}
                                    </span>
                                    <span class="hover:text-accent transition-colors">{article.author.name}</span>
                                  </span>
                                )}
                                <span>·</span>
                                <span>{article.readingTime} min read</span>
                              </div>
                            </div>

                            <!-- Arrow icon -->
                            <svg class="w-4 h-4 text-text-muted/50 dark:text-gray-600 flex-shrink-0 mt-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                            </svg>
                          </a>
                        );
                      })}
                    </div>
                  </div>
                );
              })}
            </div>
          ) : (
            <!-- Empty state -->
            <div class="text-center py-16">
              <svg class="w-16 h-16 mx-auto text-text-muted/30 dark:text-gray-700 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
              </svg>
              <h3 class="font-editorial text-xl font-bold text-text-secondary dark:text-gray-400 mb-2">
                No articles in this edition
              </h3>
              <p class="text-text-muted dark:text-gray-500">
                Articles for this edition will appear here once published.
              </p>
            </div>
          )}
        </div>

        <!-- ====== Sidebar (right 1/3) ====== -->
        <aside class="lg:col-span-1">
          <div class="lg:sticky lg:top-24 space-y-6">

            <!-- Card 1: More from This Week -->
            <div class="bg-surface dark:bg-gray-900 rounded-2xl p-6 border border-border dark:border-gray-800">
              <h3 class="font-editorial text-lg font-bold text-text-primary dark:text-gray-100 mb-5">
                More from This Week
              </h3>
              {otherEditions.length > 0 ? (
                <div class="space-y-4">
                  {otherEditions.map((otherEdition) => (
                    <a
                      href={`/editions/${otherEdition.slug}`}
                      class="flex items-start gap-3 group"
                    >
                      <!-- Edition number circle -->
                      <span class="w-9 h-9 rounded-lg bg-accent/10 dark:bg-accent/20 flex items-center justify-center flex-shrink-0">
                        <span class="text-accent font-bold text-sm">#{otherEdition.number}</span>
                      </span>
                      <div class="min-w-0">
                        <p class="text-sm font-semibold text-text-primary dark:text-gray-200 group-hover:text-accent transition-colors line-clamp-1">
                          {otherEdition.title}
                        </p>
                        <p class="text-xs text-text-muted dark:text-gray-500 mt-0.5">
                          {formatEditionDateRange(otherEdition.weekStart, otherEdition.weekEnd)}
                        </p>
                      </div>
                    </a>
                  ))}
                </div>
              ) : (
                <p class="text-sm text-text-muted dark:text-gray-500">
                  No other editions available.
                </p>
              )}

              <!-- View all link -->
              <div class="mt-5 pt-4 border-t border-border dark:border-gray-800">
                <a
                  href="/editions/archive"
                  class="text-sm text-accent font-semibold hover:text-accent-dark dark:hover:text-accent-light transition-colors"
                >
                  View All Editions →
                </a>
              </div>
            </div>

            <!-- Card 2: Print Order CTA -->
            <a
              href="/print/order"
              class="block bg-gradient-to-br from-primary to-secondary dark:from-primary dark:to-secondary text-white rounded-2xl p-6 card-hover"
            >
              <!-- Printer icon -->
              <div class="w-12 h-12 rounded-xl bg-accent-warm/20 flex items-center justify-center mb-4">
                <svg class="w-6 h-6 text-accent-warm" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 01-2-2v-5a2 2 0 012-2h16a2 2 0 012 2v5a2 2 0 01-2 2h-2"/><rect x="6" y="14" width="12" height="8"/>
                </svg>
              </div>

              <span class="text-xs font-bold text-accent-warm uppercase tracking-wider">Print Edition</span>

              <h4 class="font-editorial text-xl font-bold mt-1 mb-2">
                Print Order
              </h4>

              <p class="text-gray-300 text-sm leading-relaxed">
                Premium paper, delivered worldwide. Experience MERIDIAN in its finest form.
              </p>

              <!-- Arrow icon -->
              <div class="mt-4 flex items-center gap-1.5 text-accent-warm text-sm font-semibold">
                <span>Order Now</span>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </div>
            </a>

          </div>
        </aside>

      </div>
    </div>
  </section>

  <!-- ====== Newsletter Signup ====== -->
  <div class="bg-surface dark:bg-primary py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <NewsletterSignup variant="inline" />
    </div>
  </div>

</EditionLayout>
