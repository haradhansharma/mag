---
// Editorial Dashboard — Overview
// API-first with dummy data fallback.
// Fetches stats, activity, and queue from the Django Ninja backend.
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/common/Breadcrumbs.astro';
import { getEditorialQueue, getEditorialStats, getRecentActivity } from '@data/dummy/editorial';

// Use dummy data as server-side fallback (API calls happen client-side for auth-gated data)
const dummyStats = getEditorialStats();
const dummyActivity = getRecentActivity(10);
const dummyQueue = getEditorialQueue();
const dummyRecentSubmissions = dummyQueue.slice(0, 5);
---

<BaseLayout
  title="Editorial Dashboard — MERIDIAN"
  description="Manage your content pipeline, review submissions, and track editorial progress."
  canonicalUrl="/editorial"
>
  <div class="bg-surface dark:bg-gray-950 min-h-screen" x-data="editorialDashboard()" x-init="init()">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <!-- Breadcrumbs -->
      <Breadcrumbs items={[
        { label: 'Home', href: '/' },
        { label: 'Editorial Dashboard' },
      ]} />

      <!-- Loading State -->
      <div x-show="loading" class="flex items-center justify-center py-20">
        <svg class="animate-spin w-8 h-8 text-accent" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
        <span class="ml-3 text-text-secondary dark:text-gray-400">Loading editorial data...</span>
      </div>

      <!-- Error State -->
      <div x-show="!loading && authError" x-cloak class="flex items-center justify-center py-20">
        <div class="text-center max-w-md">
          <svg class="w-12 h-12 mx-auto text-red-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
          </svg>
          <h3 class="text-lg font-semibold text-text-primary dark:text-gray-100">Authentication Required</h3>
          <p class="text-sm text-text-secondary dark:text-gray-400 mt-2">You need to sign in as an editor or admin to access the editorial dashboard.</p>
          <a href="/auth/login?redirect=/editorial" class="inline-flex items-center gap-2 mt-4 px-5 py-2.5 bg-accent hover:bg-sky-600 text-white text-sm font-semibold rounded-xl transition-colors">
            Sign In
          </a>
        </div>
      </div>

      <!-- Main Dashboard Content -->
      <template x-if="!loading && !authError">
        <div>
          <!-- Page Header -->
          <div class="mt-6 mb-8">
            <h1 class="font-editorial text-3xl sm:text-4xl font-bold text-text-primary dark:text-gray-100">
              Editorial Dashboard
            </h1>
            <p class="mt-2 text-text-secondary dark:text-gray-400">
              Manage your content pipeline
            </p>
          </div>

          <!-- Main Grid: Sidebar + Content -->
          <div class="grid lg:grid-cols-[260px_1fr] gap-8">
            <!-- Sidebar Navigation -->
            <aside class="hidden lg:block">
              <div class="bg-white dark:bg-gray-900 rounded-2xl border border-border dark:border-gray-800 p-4 sticky top-24">
                <nav class="flex flex-col gap-1" aria-label="Editorial navigation">
                  <!-- Active: Dashboard -->
                  <a href="/editorial" class="flex items-center gap-3 px-3 py-2.5 rounded-lg bg-accent/10 text-accent font-semibold text-sm transition-colors" aria-current="page">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/>
                    </svg>
                    Dashboard
                  </a>
                  <!-- Queue -->
                  <a href="/editorial/queue" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-text-secondary dark:text-gray-400 hover:bg-surface dark:hover:bg-gray-800 text-sm transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                    </svg>
                    Queue
                  </a>
                  <!-- Articles -->
                  <a href="/editorial/articles" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-text-secondary dark:text-gray-400 hover:bg-surface dark:hover:bg-gray-800 text-sm transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                    </svg>
                    Articles
                  </a>
                  <!-- New Article -->
                  <a href="/editorial/articles/new" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-text-secondary dark:text-gray-400 hover:bg-surface dark:hover:bg-gray-800 text-sm transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                    </svg>
                    New Article
                  </a>
                  <hr class="my-2 border-border dark:border-gray-800" />
                  <!-- Print & Export (Editor Only) -->
                  <a href="/editorial#print-management" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-text-secondary dark:text-gray-400 hover:bg-surface dark:hover:bg-gray-800 text-sm transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 01-2-2v-5a2 2 0 012-2h16a2 2 0 012 2v5a2 2 0 01-2 2h-2"/><rect x="6" y="14" width="12" height="8"/>
                    </svg>
                    Print & Export
                  </a>
                  <!-- Editions Archive -->
                  <a href="/editions/archive" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-text-secondary dark:text-gray-400 hover:bg-surface dark:hover:bg-gray-800 text-sm transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
                    </svg>
                    Editions Archive
                  </a>
                </nav>

                <hr class="my-4 border-border dark:border-gray-800" />

                <!-- Quick Stats -->
                <div class="space-y-3">
                  <h3 class="text-xs font-semibold text-text-muted dark:text-gray-500 uppercase tracking-wider px-3">Quick Stats</h3>
                  <div class="flex items-center justify-between px-3">
                    <span class="text-sm text-text-secondary dark:text-gray-400">Drafts</span>
                    <span class="text-sm font-semibold text-text-primary dark:text-gray-200" x-text="stats.totalDrafts"></span>
                  </div>
                  <div class="flex items-center justify-between px-3">
                    <span class="text-sm text-text-secondary dark:text-gray-400">In Review</span>
                    <span class="text-sm font-semibold text-amber-600 dark:text-amber-400" x-text="stats.inReview"></span>
                  </div>
                  <div class="flex items-center justify-between px-3">
                    <span class="text-sm text-text-secondary dark:text-gray-400">Approved</span>
                    <span class="text-sm font-semibold text-green-600 dark:text-green-400" x-text="stats.approved"></span>
                  </div>
                  <div class="flex items-center justify-between px-3">
                    <span class="text-sm text-text-secondary dark:text-gray-400">Published</span>
                    <span class="text-sm font-semibold text-blue-600 dark:text-blue-400" x-text="stats.publishedThisWeek"></span>
                  </div>
                </div>
              </div>
            </aside>

            <!-- Main Content -->
            <div class="space-y-8">
              <!-- Stats Cards -->
              <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
                <!-- Total Articles -->
                <div class="bg-white dark:bg-gray-900 rounded-2xl border border-border dark:border-gray-800 p-5">
                  <div class="flex items-center gap-3 mb-3">
                    <div class="w-10 h-10 rounded-xl bg-blue-50 dark:bg-blue-900/20 flex items-center justify-center">
                      <svg class="w-5 h-5 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                      </svg>
                    </div>
                  </div>
                  <div class="text-2xl font-bold text-text-primary dark:text-gray-100" x-text="stats.totalArticles"></div>
                  <div class="text-sm text-text-muted dark:text-gray-500">Total Articles</div>
                </div>
                <!-- In Review -->
                <div class="bg-white dark:bg-gray-900 rounded-2xl border border-border dark:border-gray-800 p-5">
                  <div class="flex items-center gap-3 mb-3">
                    <div class="w-10 h-10 rounded-xl bg-amber-50 dark:bg-amber-900/20 flex items-center justify-center">
                      <svg class="w-5 h-5 text-amber-600 dark:text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                      </svg>
                    </div>
                  </div>
                  <div class="text-2xl font-bold text-amber-600 dark:text-amber-400" x-text="stats.inReview"></div>
                  <div class="text-sm text-text-muted dark:text-gray-500">In Review</div>
                </div>
                <!-- Published This Week -->
                <div class="bg-white dark:bg-gray-900 rounded-2xl border border-border dark:border-gray-800 p-5">
                  <div class="flex items-center gap-3 mb-3">
                    <div class="w-10 h-10 rounded-xl bg-green-50 dark:bg-green-900/20 flex items-center justify-center">
                      <svg class="w-5 h-5 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                      </svg>
                    </div>
                  </div>
                  <div class="text-2xl font-bold text-green-600 dark:text-green-400" x-text="stats.publishedThisWeek"></div>
                  <div class="text-sm text-text-muted dark:text-gray-500">Published This Week</div>
                </div>
                <!-- Avg Reading Time -->
                <div class="bg-white dark:bg-gray-900 rounded-2xl border border-border dark:border-gray-800 p-5">
                  <div class="flex items-center gap-3 mb-3">
                    <div class="w-10 h-10 rounded-xl bg-purple-50 dark:bg-purple-900/20 flex items-center justify-center">
                      <svg class="w-5 h-5 text-purple-600 dark:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                      </svg>
                    </div>
                  </div>
                  <div class="text-2xl font-bold text-text-primary dark:text-gray-100"><span x-text="stats.avgReadingTime"></span>m</div>
                  <div class="text-sm text-text-muted dark:text-gray-500">Avg Reading Time</div>
                </div>
              </div>

              <!-- Quick Actions -->
              <div class="flex flex-wrap gap-3">
                <a href="/editorial/articles/new" class="inline-flex items-center gap-2 px-5 py-2.5 bg-accent hover:bg-sky-600 text-white text-sm font-semibold rounded-xl transition-colors shadow-sm">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                  </svg>
                  Create New Article
                </a>
                <a href="/editorial/queue" class="inline-flex items-center gap-2 px-5 py-2.5 border border-border dark:border-gray-700 hover:bg-surface dark:hover:bg-gray-800 text-text-secondary dark:text-gray-300 text-sm font-semibold rounded-xl transition-colors">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                  </svg>
                  Review Queue
                </a>
              </div>

              <!-- Recent Activity + Recent Submissions -->
              <div class="grid lg:grid-cols-2 gap-8">
                <!-- Recent Activity Feed -->
                <div class="bg-white dark:bg-gray-900 rounded-2xl border border-border dark:border-gray-800 p-6">
                  <h2 class="font-editorial text-lg font-bold text-text-primary dark:text-gray-100 mb-4">Recent Activity</h2>
                  <div class="space-y-0">
                    <template x-for="item in activity.slice(0, 8)" :key="item.id">
                      <div class="flex gap-3 py-3 border-b border-border/50 dark:border-gray-800/50 last:border-0">
                        <div class="flex-shrink-0 mt-0.5">
                          <template x-if="item.action === 'published'">
                            <div class="w-8 h-8 rounded-full bg-blue-100 dark:bg-blue-900/30 flex items-center justify-center">
                              <svg class="w-4 h-4 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                            </div>
                          </template>
                          <template x-if="item.action === 'approved'">
                            <div class="w-8 h-8 rounded-full bg-green-100 dark:bg-green-900/30 flex items-center justify-center">
                              <svg class="w-4 h-4 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4"/></svg>
                            </div>
                          </template>
                          <template x-if="item.action === 'rejected'">
                            <div class="w-8 h-8 rounded-full bg-red-100 dark:bg-red-900/30 flex items-center justify-center">
                              <svg class="w-4 h-4 text-red-600 dark:text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                            </div>
                          </template>
                          <template x-if="item.action === 'submitted'">
                            <div class="w-8 h-8 rounded-full bg-amber-100 dark:bg-amber-900/30 flex items-center justify-center">
                              <svg class="w-4 h-4 text-amber-600 dark:text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
                            </div>
                          </template>
                          <template x-if="item.action === 'created' || item.action === 'edited'">
                            <div class="w-8 h-8 rounded-full bg-gray-100 dark:bg-gray-800 flex items-center justify-center">
                              <svg class="w-4 h-4 text-gray-600 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                            </div>
                          </template>
                        </div>
                        <div class="min-w-0 flex-1">
                          <p class="text-sm text-text-primary dark:text-gray-200 truncate" x-text="item.articleTitle"></p>
                          <p class="text-xs text-text-muted dark:text-gray-500 mt-0.5">
                            <span class="font-medium text-text-secondary dark:text-gray-400" x-text="item.performedBy"></span>
                            {' — '}
                            <span x-text="item.action"></span>
                          </p>
                        </div>
                      </div>
                    </template>
                    <!-- No activity fallback -->
                    <div x-show="activity.length === 0" class="text-center py-8">
                      <p class="text-sm text-text-muted dark:text-gray-500">No recent activity</p>
                    </div>
                  </div>
                </div>

                <!-- Recent Submissions Table -->
                <div class="bg-white dark:bg-gray-900 rounded-2xl border border-border dark:border-gray-800 p-6">
                  <div class="flex items-center justify-between mb-4">
                    <h2 class="font-editorial text-lg font-bold text-text-primary dark:text-gray-100">Recent Submissions</h2>
                    <a href="/editorial/queue" class="text-sm text-accent hover:text-sky-600 transition-colors font-medium">View all</a>
                  </div>
                  <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                      <thead>
                        <tr class="text-left text-text-muted dark:text-gray-500 border-b border-border dark:border-gray-800">
                          <th class="pb-3 font-medium">Title</th>
                          <th class="pb-3 font-medium hidden sm:table-cell">Author</th>
                          <th class="pb-3 font-medium">Status</th>
                          <th class="pb-3 font-medium hidden md:table-cell">Date</th>
                        </tr>
                      </thead>
                      <tbody>
                        <template x-for="item in recentSubmissions" :key="item.id">
                          <tr class="border-b border-border/50 dark:border-gray-800/50 last:border-0">
                            <td class="py-3 pr-4">
                              <span class="text-text-primary dark:text-gray-200 font-medium line-clamp-1 block max-w-[200px]" x-text="item.title"></span>
                              <span class="text-xs text-text-muted dark:text-gray-500 sm:hidden" x-text="item.authorName"></span>
                            </td>
                            <td class="py-3 pr-4 hidden sm:table-cell">
                              <span class="text-text-secondary dark:text-gray-400" x-text="item.authorName"></span>
                            </td>
                            <td class="py-3 pr-4">
                              <span :class="statusClasses(item.status)" class="inline-flex px-2.5 py-1 rounded-full text-xs font-semibold" x-text="statusLabel(item.status)"></span>
                            </td>
                            <td class="py-3 hidden md:table-cell">
                              <span class="text-text-muted dark:text-gray-500" x-text="formatDate(item.submittedAt)"></span>
                            </td>
                          </tr>
                        </template>
                        <!-- No submissions fallback -->
                        <tr x-show="recentSubmissions.length === 0">
                          <td colspan="4" class="py-8 text-center">
                            <p class="text-sm text-text-muted dark:text-gray-500">No submissions yet</p>
                          </td>
                        </tr>
                      </tbody>
                    </table>
                  </div>
                </div>
              </div>

              <!-- ==================== Print & Export Management ==================== -->
              <div id="print-management" class="mt-8">
                <div class="bg-white dark:bg-gray-900 rounded-2xl border border-border dark:border-gray-800 overflow-hidden">
                  <!-- Header -->
                  <div class="bg-gradient-to-r from-primary via-secondary to-primary p-6">
                    <div class="flex items-center gap-3">
                      <div class="w-10 h-10 rounded-xl bg-white/10 flex items-center justify-center">
                        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 01-2-2v-5a2 2 0 012-2h16a2 2 0 012 2v5a2 2 0 01-2 2h-2"/><rect x="6" y="14" width="12" height="8"/>
                        </svg>
                      </div>
                      <div>
                        <h2 class="font-editorial text-xl font-bold text-white">Print & Export</h2>
                        <p class="text-sm text-gray-300">Download print-ready PDFs for archive editions</p>
                      </div>
                    </div>
                  </div>

                  <div class="p-6">
                    <!-- Printing Guide -->
                    <div class="bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-xl p-5 mb-6">
                      <h3 class="flex items-center gap-2 text-sm font-semibold text-blue-700 dark:text-blue-400 mb-3">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                        Printing Guide
                      </h3>
                      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm text-blue-600 dark:text-blue-300">
                        <div class="space-y-2">
                          <div class="flex items-start gap-2">
                            <span class="font-bold text-blue-800 dark:text-blue-200 mt-0.5">1.</span>
                            <span>Select an edition marked as <strong>"Print Ready"</strong> from the list below</span>
                          </div>
                          <div class="flex items-start gap-2">
                            <span class="font-bold text-blue-800 dark:text-blue-200 mt-0.5">2.</span>
                            <span>Click <strong>"Print Preview"</strong> to view the edition layout before downloading</span>
                          </div>
                          <div class="flex items-start gap-2">
                            <span class="font-bold text-blue-800 dark:text-blue-200 mt-0.5">3.</span>
                            <span>Use your browser's <strong>Print dialog (Ctrl+P / Cmd+P)</strong> to export as PDF</span>
                          </div>
                        </div>
                        <div class="space-y-2">
                          <div class="flex items-start gap-2">
                            <span class="font-bold text-blue-800 dark:text-blue-200 mt-0.5">4.</span>
                            <span>Set paper size to <strong>A4</strong>, orientation to <strong>Portrait</strong></span>
                          </div>
                          <div class="flex items-start gap-2">
                            <span class="font-bold text-blue-800 dark:text-blue-200 mt-0.5">5.</span>
                            <span>Enable <strong>"Background graphics"</strong> in print settings for full color</span>
                          </div>
                          <div class="flex items-start gap-2">
                            <span class="font-bold text-blue-800 dark:text-blue-200 mt-0.5">6.</span>
                            <span>Margins: <strong>None</strong> or <strong>Minimum</strong> for best fit</span>
                          </div>
                        </div>
                      </div>
                      <div class="mt-4 pt-3 border-t border-blue-200 dark:border-blue-800">
                        <h4 class="text-xs font-semibold text-blue-700 dark:text-blue-400 uppercase tracking-wider mb-2">Print Specifications</h4>
                        <div class="grid grid-cols-3 sm:grid-cols-6 gap-2">
                          <div class="bg-white dark:bg-blue-900/30 rounded-lg p-2 text-center">
                            <div class="text-xs font-bold text-blue-800 dark:text-blue-200">A4</div>
                            <div class="text-[10px] text-blue-500">Format</div>
                          </div>
                          <div class="bg-white dark:bg-blue-900/30 rounded-lg p-2 text-center">
                            <div class="text-xs font-bold text-blue-800 dark:text-blue-200">170gsm</div>
                            <div class="text-[10px] text-blue-500">Paper</div>
                          </div>
                          <div class="bg-white dark:bg-blue-900/30 rounded-lg p-2 text-center">
                            <div class="text-xs font-bold text-blue-800 dark:text-blue-200">300 DPI</div>
                            <div class="text-[10px] text-blue-500">Resolution</div>
                          </div>
                          <div class="bg-white dark:bg-blue-900/30 rounded-lg p-2 text-center">
                            <div class="text-xs font-bold text-blue-800 dark:text-blue-200">CMYK</div>
                            <div class="text-[10px] text-blue-500">Color</div>
                          </div>
                          <div class="bg-white dark:bg-blue-900/30 rounded-lg p-2 text-center">
                            <div class="text-xs font-bold text-blue-800 dark:text-blue-200">Saddle</div>
                            <div class="text-[10px] text-blue-500">Binding</div>
                          </div>
                          <div class="bg-white dark:bg-blue-900/30 rounded-lg p-2 text-center">
                            <div class="text-xs font-bold text-blue-800 dark:text-blue-200">24-36</div>
                            <div class="text-[10px] text-blue-500">Pages</div>
                          </div>
                        </div>
                      </div>
                    </div>

                    <!-- Editions Print List -->
                    <div x-data="printManager()" x-init="loadEditions()" class="space-y-3">
                      <h3 class="text-sm font-semibold text-text-primary dark:text-gray-100 mb-3">
                        Print-Ready Editions
                      </h3>
                      <div x-show="loading" class="text-center py-8">
                        <svg class="animate-spin w-6 h-6 mx-auto text-accent mb-2" fill="none" viewBox="0 0 24 24">
                          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                        </svg>
                        <p class="text-sm text-text-muted dark:text-gray-500">Loading editions...</p>
                      </div>
                      <div x-show="!loading && editions.length === 0" class="text-center py-8">
                        <p class="text-sm text-text-muted dark:text-gray-500">No print-ready editions available. Mark editions as "Print Ready" in the edition manager.</p>
                      </div>
                      <template x-for="edition in editions" :key="edition.id">
                        <div class="flex items-center justify-between p-4 bg-surface dark:bg-gray-800 rounded-xl border border-border dark:border-gray-700">
                          <div class="flex items-center gap-4">
                            <div class="w-12 h-16 rounded-lg overflow-hidden shadow-md flex-shrink-0">
                              <img :src="edition.coverImage" :alt="edition.title" class="w-full h-full object-cover" loading="lazy" />
                            </div>
                            <div>
                              <h4 class="text-sm font-semibold text-text-primary dark:text-gray-100" x-text="`Edition #${edition.number}: ${edition.title}`"></h4>
                              <p class="text-xs text-text-muted dark:text-gray-500" x-text="`${edition.articleCount} articles`"></p>
                            </div>
                          </div>
                          <div class="flex items-center gap-2 flex-shrink-0">
                            <a
                              :href="`/print/${edition.slug}`"
                              target="_blank"
                              class="inline-flex items-center gap-1.5 px-3 py-2 text-xs font-semibold bg-accent/10 hover:bg-accent/20 text-accent rounded-lg transition-colors"
                              title="Preview print-ready edition in browser with cover, TOC, all articles, and printer guide"
                            >
                              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                              </svg>
                              Preview
                            </a>
                            <button
                              @click="openPrintDialog(edition.slug)"
                              class="inline-flex items-center gap-1.5 px-3 py-2 text-xs font-semibold bg-accent hover:bg-sky-600 text-white rounded-lg transition-colors shadow-sm"
                              title="Opens print-ready edition and triggers browser print dialog (Ctrl+P)"
                            >
                              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 01-2-2v-5a2 2 0 012-2h16a2 2 0 012 2v5a2 2 0 01-2 2h-2"/><rect x="6" y="14" width="12" height="8"/>
                              </svg>
                              Print PDF
                            </button>
                          </div>
                        </div>
                      </template>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </template>
    </div>
  </div>
</BaseLayout>

<!-- Seed data via inline script (dummy fallback) -->
<Fragment set:html={`
  <script is:inline>
    window.__meridian_dummy_stats = ${JSON.stringify(dummyStats)};
    window.__meridian_dummy_activity = ${JSON.stringify(dummyActivity)};
    window.__meridian_dummy_queue = ${JSON.stringify(dummyRecentSubmissions)};
  </script>
`} />

<script is:inline>
  function editorialDashboard() {
    const API_BASE = 'http://localhost:8085/api/v1';
    const MEDIA_BASE = 'http://localhost:8085';

    return {
      loading: true,
      authError: false,
      stats: { totalDrafts: 0, inReview: 0, approved: 0, rejected: 0, publishedThisWeek: 0, totalArticles: 0, avgReadingTime: 0 },
      activity: [],
      recentSubmissions: [],

      async init() {
        const token = localStorage.getItem('meridian_token');
        if (!token) {
          this.authError = true;
          this.loading = false;
          // Use dummy data for demo purposes
          this.useDummyData();
          return;
        }

        try {
          // Fetch all three endpoints in parallel
          const [statsRes, activityRes, queueRes] = await Promise.allSettled([
            fetch(API_BASE + '/editorial/stats/', { headers: { 'Authorization': 'Bearer ' + token } }).then(r => { if (!r.ok) throw new Error(); return r.json(); }),
            fetch(API_BASE + '/editorial/activity/?limit=10', { headers: { 'Authorization': 'Bearer ' + token } }).then(r => { if (!r.ok) throw new Error(); return r.json(); }),
            fetch(API_BASE + '/editorial/queue/?page_size=5', { headers: { 'Authorization': 'Bearer ' + token } }).then(r => { if (!r.ok) throw new Error(); return r.json(); }),
          ]);

          if (statsRes.status === 'fulfilled') {
            const s = statsRes.value;
            this.stats = {
              totalDrafts: s.total_drafts || 0,
              inReview: s.in_review || 0,
              approved: s.approved || 0,
              rejected: s.rejected || 0,
              publishedThisWeek: s.published_this_week || 0,
              totalArticles: s.total_articles || 0,
              avgReadingTime: s.avg_reading_time || 0,
            };
          }

          if (activityRes.status === 'fulfilled') {
            this.activity = (activityRes.value || []).map(a => ({
              id: a.id,
              action: a.action,
              articleTitle: a.article_title,
              performedBy: a.performed_by_name,
              timestamp: a.timestamp,
            }));
          }

          if (queueRes.status === 'fulfilled') {
            this.recentSubmissions = (queueRes.value.results || []).map(q => ({
              id: q.id,
              title: q.title,
              authorName: q.author_name,
              status: q.status,
              submittedAt: q.submitted_at,
              coverImage: q.cover_image ? (q.cover_image.startsWith('http') ? q.cover_image : MEDIA_BASE + q.cover_image) : '',
            }));
          }

          // If all API calls failed, fall back to dummy data
          if (statsRes.status === 'rejected' && activityRes.status === 'rejected' && queueRes.status === 'rejected') {
            this.useDummyData();
          }
        } catch (e) {
          this.useDummyData();
        } finally {
          this.loading = false;
        }
      },

      useDummyData() {
        const ds = window.__meridian_dummy_stats || {};
        this.stats = {
          totalDrafts: ds.totalDrafts || 0,
          inReview: ds.inReview || 0,
          approved: ds.approved || 0,
          rejected: ds.rejected || 0,
          publishedThisWeek: ds.publishedThisWeek || 0,
          totalArticles: ds.totalArticles || 0,
          avgReadingTime: ds.avgReadingTime || 0,
        };
        this.activity = (window.__meridian_dummy_activity || []).map(a => ({
          id: a.id,
          action: a.action,
          articleTitle: a.articleTitle,
          performedBy: a.performedBy,
          timestamp: a.timestamp,
        }));
        this.recentSubmissions = (window.__meridian_dummy_queue || []).map(q => ({
          id: q.id,
          title: q.title,
          authorName: q.authorName,
          status: q.status,
          submittedAt: q.submittedAt,
          coverImage: q.coverImage,
        }));
      },

      statusClasses(status) {
        const map = {
          draft: 'bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300',
          in_review: 'bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400',
          approved: 'bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400',
          rejected: 'bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-400',
          published: 'bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-400',
        };
        return map[status] || map.draft;
      },

      statusLabel(status) {
        const map = { draft: 'Draft', in_review: 'In Review', approved: 'Approved', rejected: 'Rejected', published: 'Published' };
        return map[status] || status;
      },

      formatDate(dateStr) {
        if (!dateStr) return '';
        return new Date(dateStr).toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
      },
    };
  }

  function printManager() {
    const API_BASE = 'http://localhost:8085/api/v1';
    const MEDIA_BASE = 'http://localhost:8085';
    return {
      loading: true,
      editions: [],
      async loadEditions() {
        try {
          const token = localStorage.getItem('meridian_token');
          const headers = { 'Accept': 'application/json' };
          if (token) headers['Authorization'] = 'Bearer ' + token;
          const res = await fetch(`${API_BASE}/editions/?page_size=100`, { headers });
          if (res.ok) {
            const data = await res.json();
            this.editions = (data.results || [])
              .filter(e => e.print_ready)
              .map(e => ({
                id: e.id,
                number: e.number,
                title: e.title,
                slug: e.slug,
                articleCount: e.article_count || 0,
                coverImage: e.cover_image ? (e.cover_image.startsWith('http') ? e.cover_image : MEDIA_BASE + e.cover_image) : '',
              }));
          }
        } catch (e) { /* Silent fail */ }
        this.loading = false;
      },
      openPrintDialog(slug) {
        // Open the print-ready page in a new tab and trigger the browser print dialog
        const printWindow = window.open(`/print/${slug}`, '_blank');
        if (printWindow) {
          // Wait for the page to load, then trigger print
          printWindow.addEventListener('load', function onLoaded() {
            printWindow.removeEventListener('load', onLoaded);
            // Small delay to ensure all resources (fonts, images) are loaded
            setTimeout(() => {
              printWindow.print();
            }, 800);
          });
        }
      },
    };
  }
</script>
