---
// Article Management — CRUD list with table/card view toggle
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/common/Breadcrumbs.astro';
import { getEditorialQueue, getEditorialStats } from '@data/dummy/editorial';

const queue = getEditorialQueue();
const stats = getEditorialStats();
---

<BaseLayout
  title="Article Management — MERIDIAN"
  description="Manage all articles in the editorial system."
  canonicalUrl="/editorial/articles"
>
  <div class="bg-surface dark:bg-gray-950 min-h-screen" x-data="articleManager()" x-init="init()">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <!-- Breadcrumbs -->
      <Breadcrumbs items={[
        { label: 'Home', href: '/' },
        { label: 'Editorial', href: '/editorial' },
        { label: 'Articles' },
      ]} />

      <!-- Page Header -->
      <div class="mt-6 mb-6">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
          <div>
            <h1 class="font-editorial text-3xl sm:text-4xl font-bold text-text-primary dark:text-gray-100">
              Article Management
            </h1>
            <p class="mt-2 text-text-secondary dark:text-gray-400">
              <span x-text="articles.length"></span> total articles
            </p>
          </div>
          <a href="/editorial/articles/new" class="inline-flex items-center gap-2 px-5 py-2.5 bg-accent hover:bg-sky-600 text-white text-sm font-semibold rounded-xl transition-colors shadow-sm">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
            </svg>
            New Article
          </a>
        </div>

        <!-- Search + Filter + View Toggle -->
        <div class="mt-6 flex flex-col sm:flex-row gap-3">
          <!-- Search -->
          <div class="relative flex-1">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-text-muted dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
            <input
              type="text"
              placeholder="Search articles..."
              x-model="search"
              class="w-full pl-10 pr-4 py-2.5 bg-white dark:bg-gray-900 border border-border dark:border-gray-700 rounded-xl text-sm text-text-primary dark:text-gray-200 placeholder-text-muted dark:placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent transition-colors"
            />
          </div>
          <!-- Category Filter -->
          <select
            x-model="categoryFilter"
            class="px-4 py-2.5 bg-white dark:bg-gray-900 border border-border dark:border-gray-700 rounded-xl text-sm text-text-primary dark:text-gray-200 focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent transition-colors"
          >
            <option value="all">All Categories</option>
            <option value="Science & Tech">Science & Tech</option>
            <option value="World News">World News</option>
            <option value="Environment">Environment</option>
            <option value="Culture">Culture</option>
            <option value="Health">Health</option>
          </select>
          <!-- View Toggle -->
          <div class="flex items-center border border-border dark:border-gray-700 rounded-xl overflow-hidden">
            <button
              @click="viewMode = 'table'"
              :class="viewMode === 'table' ? 'bg-accent text-white' : 'bg-white dark:bg-gray-900 text-text-muted dark:text-gray-400 hover:bg-surface dark:hover:bg-gray-800'"
              class="px-3 py-2.5 transition-colors"
              aria-label="Table view"
              :aria-pressed="viewMode === 'table'"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"/></svg>
            </button>
            <button
              @click="viewMode = 'card'"
              :class="viewMode === 'card' ? 'bg-accent text-white' : 'bg-white dark:bg-gray-900 text-text-muted dark:text-gray-400 hover:bg-surface dark:hover:bg-gray-800'"
              class="px-3 py-2.5 transition-colors"
              aria-label="Card view"
              :aria-pressed="viewMode === 'card'"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
            </button>
          </div>
        </div>
      </div>

      <!-- Table View -->
      <div x-show="viewMode === 'table'" class="bg-white dark:bg-gray-900 rounded-2xl border border-border dark:border-gray-800 overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="text-left text-text-muted dark:text-gray-500 border-b border-border dark:border-gray-800 bg-surface/50 dark:bg-gray-800/50">
                <th class="px-6 py-3 font-medium">Title</th>
                <th class="px-4 py-3 font-medium hidden md:table-cell">Author</th>
                <th class="px-4 py-3 font-medium hidden sm:table-cell">Category</th>
                <th class="px-4 py-3 font-medium">Status</th>
                <th class="px-4 py-3 font-medium hidden lg:table-cell">Updated</th>
                <th class="px-4 py-3 font-medium text-right">Actions</th>
              </tr>
            </thead>
            <tbody>
              <template x-for="item in filteredArticles" :key="item.id">
                <tr class="border-b border-border/50 dark:border-gray-800/50 last:border-0 hover:bg-surface/50 dark:hover:bg-gray-800/30 transition-colors">
                  <td class="px-6 py-4">
                    <div class="flex items-center gap-3">
                      <img :src="item.coverImage" :alt="item.title" class="w-10 h-10 rounded-lg object-cover flex-shrink-0 hidden sm:block" loading="lazy" />
                      <span class="text-text-primary dark:text-gray-200 font-medium line-clamp-1" x-text="item.title"></span>
                    </div>
                  </td>
                  <td class="px-4 py-4 hidden md:table-cell">
                    <span class="text-text-secondary dark:text-gray-400" x-text="item.authorName"></span>
                  </td>
                  <td class="px-4 py-4 hidden sm:table-cell">
                    <span class="px-2 py-0.5 rounded-md bg-surface dark:bg-gray-800 text-xs font-medium text-text-secondary dark:text-gray-400" x-text="item.category"></span>
                  </td>
                  <td class="px-4 py-4">
                    <span :class="statusClasses(item.status)" class="inline-flex px-2.5 py-1 rounded-full text-xs font-semibold" x-text="statusLabel(item.status)"></span>
                  </td>
                  <td class="px-4 py-4 hidden lg:table-cell">
                    <span class="text-text-muted dark:text-gray-500" x-text="formatDate(item.updatedAt)"></span>
                  </td>
                  <td class="px-4 py-4 text-right">
                    <div class="flex items-center justify-end gap-1">
                      <a :href="'/editorial/articles/' + item.id" class="p-2 rounded-lg text-text-muted dark:text-gray-500 hover:text-accent hover:bg-accent/10 transition-colors" aria-label="Edit article">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                      </a>
                      <button @click="openDeleteModal(item)" class="p-2 rounded-lg text-text-muted dark:text-gray-500 hover:text-red-600 hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors" aria-label="Delete article">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                      </button>
                    </div>
                  </td>
                </tr>
              </template>
            </tbody>
          </table>
        </div>
        <!-- Empty State -->
        <div x-show="filteredArticles.length === 0" x-cloak class="p-12 text-center">
          <svg class="w-12 h-12 mx-auto text-text-muted dark:text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          <p class="mt-4 text-text-secondary dark:text-gray-400 font-medium">No articles found</p>
        </div>
      </div>

      <!-- Card View -->
      <div x-show="viewMode === 'card'" x-cloak class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        <template x-for="item in filteredArticles" :key="item.id">
          <div class="bg-white dark:bg-gray-900 rounded-2xl border border-border dark:border-gray-800 overflow-hidden card-hover group">
            <div class="relative h-40 overflow-hidden">
              <img :src="item.coverImage" :alt="item.title" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
              <div class="absolute top-3 left-3">
                <span :class="statusClasses(item.status)" class="inline-flex px-2.5 py-1 rounded-full text-xs font-semibold backdrop-blur-sm" x-text="statusLabel(item.status)"></span>
              </div>
            </div>
            <div class="p-5">
              <span class="text-xs font-semibold text-accent uppercase tracking-wider" x-text="item.category"></span>
              <h3 class="mt-1 font-semibold text-text-primary dark:text-gray-100 line-clamp-2" x-text="item.title"></h3>
              <p class="mt-1 text-sm text-text-muted dark:text-gray-500" x-text="item.authorName"></p>
              <div class="flex items-center justify-between mt-4 pt-4 border-t border-border/50 dark:border-gray-800/50">
                <span class="text-xs text-text-muted dark:text-gray-500" x-text="item.readingTime + ' min read'"></span>
                <div class="flex items-center gap-1">
                  <a :href="'/editorial/articles/' + item.id" class="p-2 rounded-lg text-text-muted dark:text-gray-500 hover:text-accent hover:bg-accent/10 transition-colors" aria-label="Edit">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                  </a>
                  <button @click="openDeleteModal(item)" class="p-2 rounded-lg text-text-muted dark:text-gray-500 hover:text-red-600 hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors" aria-label="Delete">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                  </button>
                </div>
              </div>
            </div>
          </div>
        </template>
        <!-- Empty State -->
        <div x-show="filteredArticles.length === 0" x-cloak class="col-span-full p-12 text-center bg-white dark:bg-gray-900 rounded-2xl border border-border dark:border-gray-800">
          <p class="text-text-secondary dark:text-gray-400 font-medium">No articles found</p>
        </div>
      </div>

      <!-- Delete Confirmation Modal -->
      <div
        x-show="showDeleteModal"
        x-cloak
        class="fixed inset-0 z-50 flex items-center justify-center p-4"
        @keydown.escape.window="showDeleteModal = false"
      >
        <div class="fixed inset-0 bg-black/50" @click="showDeleteModal = false"></div>
        <div class="relative bg-white dark:bg-gray-900 rounded-2xl border border-border dark:border-gray-800 p-6 w-full max-w-md shadow-xl z-10"
          x-transition:enter="transition ease-out duration-200"
          x-transition:enter-start="opacity-0 scale-95"
          x-transition:enter-end="opacity-100 scale-100"
          x-transition:leave="transition ease-in duration-150"
          x-transition:leave-start="opacity-100 scale-100"
          x-transition:leave-end="opacity-0 scale-95"
        >
          <div class="w-12 h-12 rounded-full bg-red-100 dark:bg-red-900/20 flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-red-600 dark:text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
          </div>
          <h3 class="font-editorial text-lg font-bold text-text-primary dark:text-gray-100 text-center">Delete Article</h3>
          <p class="text-sm text-text-secondary dark:text-gray-400 mt-2 text-center">
            Are you sure you want to delete "<span class="font-medium text-text-primary dark:text-gray-200" x-text="deleteTarget?.title"></span>"? This action cannot be undone.
          </p>
          <div class="flex justify-center gap-3 mt-6">
            <button @click="showDeleteModal = false" class="px-5 py-2.5 border border-border dark:border-gray-700 hover:bg-surface dark:hover:bg-gray-800 text-text-secondary dark:text-gray-300 text-sm font-semibold rounded-xl transition-colors">
              Cancel
            </button>
            <button @click="confirmDelete()" class="px-5 py-2.5 bg-red-500 hover:bg-red-600 text-white text-sm font-semibold rounded-xl transition-colors">
              Delete
            </button>
          </div>
        </div>
      </div>

      <!-- Toast Notification -->
      <div
        x-show="toast.show"
        x-cloak
        x-transition:enter="transition ease-out duration-300"
        x-transition:enter-start="opacity-0 translate-y-4"
        x-transition:enter-end="opacity-100 translate-y-0"
        x-transition:leave="transition ease-in duration-200"
        x-transition:leave-start="opacity-100 translate-y-0"
        x-transition:leave-end="opacity-0 translate-y-4"
        class="fixed bottom-6 right-6 z-50"
      >
        <div :class="toast.type === 'success' ? 'bg-green-600' : 'bg-red-600'" class="px-5 py-3 rounded-xl shadow-lg text-white text-sm font-medium flex items-center gap-2">
          <svg x-show="toast.type === 'success'" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          <span x-text="toast.message"></span>
        </div>
      </div>
    </div>
  </div>

  <!-- Seed data -->
  <Fragment set:html={`
    <script is:inline>
      window.__meridian_articles = ${JSON.stringify(queue)};
    </script>
  `} />

  <script is:inline>
    function articleManager() {
      return {
        articles: [],
        search: '',
        categoryFilter: 'all',
        viewMode: 'table',
        showDeleteModal: false,
        deleteTarget: null,
        toast: { show: false, message: '', type: 'success' },
        toastTimer: null,

        init() {
          this.articles = JSON.parse(JSON.stringify(window.__meridian_articles));
        },

        get filteredArticles() {
          let items = this.articles;
          if (this.categoryFilter !== 'all') {
            items = items.filter(i => i.category === this.categoryFilter);
          }
          if (this.search.trim()) {
            const q = this.search.toLowerCase();
            items = items.filter(i =>
              i.title.toLowerCase().includes(q) ||
              i.authorName.toLowerCase().includes(q)
            );
          }
          return items;
        },

        openDeleteModal(item) {
          this.deleteTarget = item;
          this.showDeleteModal = true;
        },

        confirmDelete() {
          if (this.deleteTarget) {
            this.articles = this.articles.filter(i => i.id !== this.deleteTarget.id);
            this.showToast('Article deleted successfully', 'success');
          }
          this.showDeleteModal = false;
          this.deleteTarget = null;
        },

        showToast(message, type = 'success') {
          if (this.toastTimer) clearTimeout(this.toastTimer);
          this.toast = { show: true, message, type };
          this.toastTimer = setTimeout(() => { this.toast.show = false; }, 3000);
        },

        statusClasses(status) {
          const map = {
            draft: 'bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300',
            in_review: 'bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400',
            approved: 'bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400',
            rejected: 'bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-400',
            published: 'bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-400',
          };
          return map[status] || map.draft;
        },

        statusLabel(status) {
          const map = { draft: 'Draft', in_review: 'In Review', approved: 'Approved', rejected: 'Rejected', published: 'Published' };
          return map[status] || status;
        },

        formatDate(dateStr) {
          return new Date(dateStr).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
        },
      };
    }
  </script>
</BaseLayout>
