---
/**
 * Login Page — /auth/login
 * Email + password login with OTP registration option.
 * Uses Alpine.js for client-side interactivity.
 * Communicates with Django Ninja backend API.
 */

import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/common/Breadcrumbs.astro';

const API_BASE = 'http://localhost:8085/api/v1';
---

<BaseLayout
  title="Login — MERIDIAN Magazine"
  description="Sign in to your MERIDIAN account to access premium content, manage subscriptions, and more."
  canonicalUrl="/auth/login"
>
  <div class="page-transition">
    <div class="min-h-[80vh] flex items-center justify-center py-16 px-4">
      <div class="w-full max-w-md">
        <!-- Logo -->
        <div class="text-center mb-8">
          <a href="/" class="inline-flex items-center gap-2 group">
            <div class="w-10 h-10 bg-accent rounded-sm flex items-center justify-center">
              <span class="text-white font-bold text-lg font-editorial">M</span>
            </div>
            <span class="font-editorial text-2xl font-bold tracking-wide text-primary dark:text-white group-hover:text-accent transition-colors">
              MERIDIAN
            </span>
          </a>
          <p class="text-text-secondary dark:text-gray-400 mt-3 text-sm">Sign in to access your account</p>
        </div>

        <!-- Login/Register Card -->
        <div
          x-data="authForm()"
          class="bg-white dark:bg-gray-900 rounded-2xl border border-border dark:border-gray-800 shadow-sm overflow-hidden"
        >
          <!-- Tab Header -->
          <div class="flex border-b border-border dark:border-gray-800">
            <button
              @click="mode = 'login'"
              :class="mode === 'login' ? 'text-accent border-b-2 border-accent' : 'text-text-muted dark:text-gray-500 hover:text-text-secondary dark:hover:text-gray-400'"
              class="flex-1 py-4 text-sm font-semibold transition-colors text-center"
            >
              Sign In
            </button>
            <button
              @click="mode = 'register'"
              :class="mode === 'register' ? 'text-accent border-b-2 border-accent' : 'text-text-muted dark:text-gray-500 hover:text-text-secondary dark:hover:text-gray-400'"
              class="flex-1 py-4 text-sm font-semibold transition-colors text-center"
            >
              Create Account
            </button>
          </div>

          <div class="p-6 sm:p-8">
            <!-- ==================== LOGIN FORM ==================== -->
            <form x-show="mode === 'login'" @submit.prevent="handleLogin()" class="space-y-5">
              <!-- Error Message -->
              <div x-show="error" x-cloak class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg p-3">
                <p class="text-red-600 dark:text-red-400 text-sm" x-text="error"></p>
              </div>

              <div>
                <label class="block text-sm font-medium text-text-secondary dark:text-gray-400 mb-2">
                  Username or Email
                </label>
                <div class="relative">
                  <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-text-muted dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                  </svg>
                  <input
                    type="text"
                    x-model="loginForm.username"
                    required
                    placeholder="Enter your username or email"
                    class="w-full pl-10 pr-4 py-3 rounded-lg border border-border dark:border-gray-600 bg-surface dark:bg-gray-800 text-primary dark:text-white placeholder-text-muted dark:placeholder-gray-500 text-sm focus:outline-none focus:ring-2 focus:ring-accent"
                  />
                </div>
              </div>

              <div>
                <label class="block text-sm font-medium text-text-secondary dark:text-gray-400 mb-2">
                  Password
                </label>
                <div class="relative">
                  <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-text-muted dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
                  </svg>
                  <input
                    :type="showPassword ? 'text' : 'password'"
                    x-model="loginForm.password"
                    required
                    placeholder="Enter your password"
                    class="w-full pl-10 pr-12 py-3 rounded-lg border border-border dark:border-gray-600 bg-surface dark:bg-gray-800 text-primary dark:text-white placeholder-text-muted dark:placeholder-gray-500 text-sm focus:outline-none focus:ring-2 focus:ring-accent"
                  />
                  <button
                    type="button"
                    @click="showPassword = !showPassword"
                    class="absolute right-3 top-1/2 -translate-y-1/2 text-text-muted dark:text-gray-500 hover:text-text-secondary dark:hover:text-gray-400 transition-colors"
                  >
                    <svg x-show="!showPassword" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                    <svg x-show="showPassword" x-cloak class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/></svg>
                  </button>
                </div>
              </div>

              <!-- Remember me + Forgot -->
              <div class="flex items-center justify-between">
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="checkbox" x-model="loginForm.remember" class="w-4 h-4 rounded border-border dark:border-gray-600 text-accent focus:ring-accent" />
                  <span class="text-sm text-text-secondary dark:text-gray-400">Remember me</span>
                </label>
                <a href="#" class="text-sm text-accent hover:underline">Forgot password?</a>
              </div>

              <!-- Submit -->
              <button
                type="submit"
                :disabled="loading"
                class="w-full bg-accent hover:bg-sky-600 disabled:bg-accent/50 text-white font-semibold py-3 rounded-xl text-sm transition-colors flex items-center justify-center gap-2"
              >
                <svg x-show="loading" class="animate-spin w-4 h-4" fill="none" viewBox="0 0 24 24">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
                <span x-text="loading ? 'Signing in...' : 'Sign In'"></span>
              </button>

              <!-- Success Message -->
              <div x-show="success" x-cloak class="bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-lg p-4 text-center">
                <svg class="w-8 h-8 mx-auto text-green-500 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                <p class="text-green-700 dark:text-green-400 font-medium">Signed in successfully!</p>
                <p class="text-green-600 dark:text-green-500 text-sm mt-1">Redirecting...</p>
              </div>
            </form>

            <!-- ==================== REGISTER FORM ==================== -->
            <form x-show="mode === 'register'" @submit.prevent="handleRegister()" class="space-y-5">
              <!-- Error Message -->
              <div x-show="error" x-cloak class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg p-3">
                <p class="text-red-600 dark:text-red-400 text-sm" x-text="error"></p>
              </div>

              <div>
                <label class="block text-sm font-medium text-text-secondary dark:text-gray-400 mb-2">
                  Username
                </label>
                <input
                  type="text"
                  x-model="registerForm.username"
                  required
                  placeholder="Choose a username"
                  class="w-full px-4 py-3 rounded-lg border border-border dark:border-gray-600 bg-surface dark:bg-gray-800 text-primary dark:text-white placeholder-text-muted dark:placeholder-gray-500 text-sm focus:outline-none focus:ring-2 focus:ring-accent"
                />
              </div>

              <div>
                <label class="block text-sm font-medium text-text-secondary dark:text-gray-400 mb-2">
                  Email Address
                </label>
                <input
                  type="email"
                  x-model="registerForm.email"
                  required
                  placeholder="Enter your email address"
                  class="w-full px-4 py-3 rounded-lg border border-border dark:border-gray-600 bg-surface dark:bg-gray-800 text-primary dark:text-white placeholder-text-muted dark:placeholder-gray-500 text-sm focus:outline-none focus:ring-2 focus:ring-accent"
                />
              </div>

              <div>
                <label class="block text-sm font-medium text-text-secondary dark:text-gray-400 mb-2">
                  Password
                </label>
                <div class="relative">
                  <input
                    :type="showPassword ? 'text' : 'password'"
                    x-model="registerForm.password"
                    required
                    minlength="8"
                    placeholder="Min. 8 characters"
                    class="w-full px-4 pr-12 py-3 rounded-lg border border-border dark:border-gray-600 bg-surface dark:bg-gray-800 text-primary dark:text-white placeholder-text-muted dark:placeholder-gray-500 text-sm focus:outline-none focus:ring-2 focus:ring-accent"
                  />
                  <button
                    type="button"
                    @click="showPassword = !showPassword"
                    class="absolute right-3 top-1/2 -translate-y-1/2 text-text-muted dark:text-gray-500 hover:text-text-secondary dark:hover:text-gray-400 transition-colors"
                  >
                    <svg x-show="!showPassword" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                    <svg x-show="showPassword" x-cloak class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/></svg>
                  </button>
                </div>
              </div>

              <!-- Terms -->
              <label class="flex items-start gap-3 cursor-pointer group">
                <input
                  type="checkbox"
                  x-model="registerForm.agreeTerms"
                  required
                  class="mt-1 w-4 h-4 rounded border-border dark:border-gray-600 text-accent focus:ring-accent"
                />
                <span class="text-sm text-text-secondary dark:text-gray-400 group-hover:text-primary dark:group-hover:text-gray-300 transition-colors">
                  I agree to the <a href="/terms" target="_blank" class="text-accent hover:underline">Terms of Service</a> and <a href="/privacy" target="_blank" class="text-accent hover:underline">Privacy Policy</a>.
                </span>
              </label>

              <!-- Submit -->
              <button
                type="submit"
                :disabled="loading"
                class="w-full bg-accent hover:bg-sky-600 disabled:bg-accent/50 text-white font-semibold py-3 rounded-xl text-sm transition-colors flex items-center justify-center gap-2"
              >
                <svg x-show="loading" class="animate-spin w-4 h-4" fill="none" viewBox="0 0 24 24">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
                <span x-text="loading ? 'Creating account...' : 'Create Account'"></span>
              </button>

              <!-- Success Message -->
              <div x-show="success" x-cloak class="bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-lg p-4 text-center">
                <svg class="w-8 h-8 mx-auto text-green-500 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                <p class="text-green-700 dark:text-green-400 font-medium">Account created successfully!</p>
                <p class="text-green-600 dark:text-green-500 text-sm mt-1">Redirecting...</p>
              </div>
            </form>

            <!-- Divider -->
            <div class="flex items-center gap-4 my-6">
              <div class="flex-1 h-px bg-border dark:bg-gray-800"></div>
              <span class="text-xs text-text-muted dark:text-gray-500 uppercase tracking-wider">or continue with</span>
              <div class="flex-1 h-px bg-border dark:bg-gray-800"></div>
            </div>

            <!-- Back to home -->
            <div class="text-center">
              <a href="/" class="text-sm text-text-muted dark:text-gray-500 hover:text-accent dark:hover:text-accent-light transition-colors">
                ← Back to homepage
              </a>
            </div>
          </div>
        </div>

        <!-- Test Accounts Info -->
        <div class="mt-6 bg-surface dark:bg-gray-900 rounded-xl border border-border dark:border-gray-700 p-4">
          <h4 class="text-xs font-semibold text-text-muted dark:text-gray-500 uppercase tracking-wider mb-2">Demo Accounts</h4>
          <div class="space-y-1.5 text-xs text-text-secondary dark:text-gray-400">
            <div class="flex items-center justify-between">
              <span>Admin</span>
              <code class="bg-surface-alt dark:bg-gray-800 px-2 py-0.5 rounded text-text-muted dark:text-gray-500">admin@meridian.com / admin123</code>
            </div>
            <div class="flex items-center justify-between">
              <span>Editor</span>
              <code class="bg-surface-alt dark:bg-gray-800 px-2 py-0.5 rounded text-text-muted dark:text-gray-500">editor@meridian.com / editor123</code>
            </div>
            <div class="flex items-center justify-between">
              <span>Writer</span>
              <code class="bg-surface-alt dark:bg-gray-800 px-2 py-0.5 rounded text-text-muted dark:text-gray-500">writer@meridian.com / writer123</code>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    function authForm() {
      const API_BASE = 'http://localhost:8085/api/v1';

      return {
        mode: 'login',
        showPassword: false,
        loading: false,
        error: '',
        success: false,

        loginForm: {
          username: '',
          password: '',
          remember: false,
        },

        registerForm: {
          username: '',
          email: '',
          password: '',
          agreeTerms: false,
        },

        async handleLogin() {
          this.error = '';
          this.loading = true;
          try {
            const res = await fetch(API_BASE + '/auth/login/', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                username: this.loginForm.username,
                password: this.loginForm.password,
              }),
            });
            if (!res.ok) {
              const err = await res.json().catch(() => ({}));
              throw new Error(err.detail || `Login failed (${res.status})`);
            }
            const data = await res.json();
            // Store auth token
            localStorage.setItem('meridian_token', data.token);
            localStorage.setItem('meridian_user', JSON.stringify({
              id: data.user_id,
              username: data.username,
              role: data.role,
            }));
            this.success = true;
            // Redirect after short delay
            // Redirect to original page after login, or home if none specified
            const redirectUrl = new URLSearchParams(window.location.search).get('redirect') || '/';
            setTimeout(() => {
              window.location.href = redirectUrl;
            }, 1500);
          } catch (e) {
            this.error = e.message;
          } finally {
            this.loading = false;
          }
        },

        async handleRegister() {
          this.error = '';
          if (!this.registerForm.agreeTerms) {
            this.error = 'You must agree to the Terms of Service.';
            return;
          }
          this.loading = true;
          try {
            const res = await fetch(API_BASE + '/auth/register/', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                username: this.registerForm.username,
                email: this.registerForm.email,
                password: this.registerForm.password,
              }),
            });
            if (!res.ok) {
              const err = await res.json().catch(() => ({}));
              throw new Error(err.detail || `Registration failed (${res.status})`);
            }
            const data = await res.json();
            localStorage.setItem('meridian_token', data.token);
            localStorage.setItem('meridian_user', JSON.stringify({
              id: data.user_id,
              username: data.username,
              role: data.role,
            }));
            this.success = true;
            const redirectUrl = new URLSearchParams(window.location.search).get('redirect') || '/';
            setTimeout(() => {
              window.location.href = redirectUrl;
            }, 1500);
          } catch (e) {
            this.error = e.message;
          } finally {
            this.loading = false;
          }
        },
      };
    }
  </script>
</BaseLayout>
