---
/**
 * Forgot Password Page — /auth/forgot-password
 * Enter email to receive a password reset link.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/common/Breadcrumbs.astro';
---

<BaseLayout
  title="Forgot Password — MERIDIAN Magazine"
  description="Reset your MERIDIAN password. Enter your email to receive a secure reset link."
  canonicalUrl="/auth/forgot-password"
>
  <div class="page-transition">
    <div class="min-h-[80vh] flex items-center justify-center py-12 px-4">
      <div class="w-full max-w-md">
        <!-- Breadcrumbs -->
        <div class="mb-8">
          <Breadcrumbs items={[
            { label: 'Home', href: '/' },
            { label: 'Sign In', href: '/auth/login' },
            { label: 'Forgot Password' },
          ]} />
        </div>

        <!-- Card -->
        <div
          x-data="forgotPasswordForm()"
          class="bg-white dark:bg-gray-900 rounded-2xl border border-border dark:border-gray-800 shadow-sm overflow-hidden"
        >
          <!-- Header -->
          <div class="bg-gradient-to-br from-primary via-secondary to-primary p-8 text-center">
            <div class="w-12 h-12 bg-accent/20 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/>
              </svg>
            </div>
            <h1 class="font-editorial text-2xl font-bold text-white">Reset Your Password</h1>
            <p class="text-gray-300 text-sm mt-1">We'll send you a secure link to reset your password</p>
          </div>

          <!-- Form -->
          <div class="p-6 sm:p-8">
            <form x-show="!sent" @submit.prevent="handleSubmit()" class="space-y-5">
              <!-- Email -->
              <div>
                <label for="fp-email" class="block text-sm font-medium text-text-secondary dark:text-gray-400 mb-1.5">
                  Email Address
                </label>
                <input
                  type="email"
                  id="fp-email"
                  x-model="email"
                  required
                  placeholder="Enter your registered email"
                  class="w-full px-4 py-3 bg-surface dark:bg-gray-800 border border-border dark:border-gray-700 rounded-xl text-sm text-text-primary dark:text-gray-100 placeholder-text-muted dark:placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent transition-colors"
                />
              </div>

              <!-- Error -->
              <div x-show="error" x-cloak class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-xl p-3">
                <p class="text-sm text-red-600 dark:text-red-400" x-text="error"></p>
              </div>

              <!-- Submit -->
              <button
                type="submit"
                :disabled="loading"
                class="w-full py-3.5 bg-accent hover:bg-sky-600 disabled:bg-accent/50 disabled:cursor-not-allowed text-white font-semibold rounded-xl text-sm transition-colors"
              >
                <span x-text="loading ? 'Sending...' : 'Send Reset Link'"></span>
              </button>
            </form>

            <!-- Success -->
            <div x-show="sent" x-cloak x-transition class="text-center py-4">
              <svg class="w-12 h-12 mx-auto text-green-500 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              <h3 class="font-semibold text-text-primary dark:text-gray-100 text-lg">Check Your Email</h3>
              <p class="text-sm text-text-secondary dark:text-gray-400 mt-2">
                If an account exists with <strong x-text="email"></strong>, you'll receive a password reset link shortly.
              </p>
              <a href="/auth/login" class="inline-flex items-center gap-1 mt-4 text-accent hover:text-sky-600 text-sm font-semibold transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
                </svg>
                Back to Sign In
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script is:inline>
function forgotPasswordForm() {
  return {
    email: '',
    loading: false,
    error: '',
    sent: false,

    async handleSubmit() {
      this.error = '';
      if (!this.email.trim() || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(this.email)) {
        this.error = 'Please enter a valid email address.';
        return;
      }
      this.loading = true;
      try {
        const API_BASE = (typeof import.meta !== 'undefined' && import.meta.env && import.meta.env.PUBLIC_API_URL) || 'http://localhost:8085/api/v1';
        const res = await fetch(`${API_BASE}/auth/forgot-password/`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: this.email.trim() }),
        });
        const data = await res.json();
        // Always show success (security best practice — don't reveal if email exists)
        this.sent = true;
      } catch (err) {
        this.error = 'Unable to connect to server. Please try again.';
      } finally {
        this.loading = false;
      }
    },
  };
}
</script>
