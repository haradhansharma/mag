---
// CoverTemplate.astro
// Full-page magazine cover component for print.
// Image is placed as a contained element (not full-bleed) so the
// full image is visible without cropping.

import type { Edition } from '@data/types';
import { formatEditionDateRange } from '@utils/helpers';

interface Props {
  edition: Edition;
}

const { edition } = Astro.props;
const dateRange = formatEditionDateRange(edition.weekStart, edition.weekEnd);
---

<div class="print-cover">
  <!-- Decorative accent bar -->
  <div style="
    position: absolute; top: 0; left: 0; right: 0; height: 4pt;
    background: linear-gradient(90deg, #0EA5E9 0%, #38BDF8 50%, #F59E0B 100%);
    z-index: 2;
  "></div>

  <!-- Subtle geometric pattern overlay -->
  <div style="
    position: absolute; inset: 0; z-index: 0;
    background:
      radial-gradient(ellipse at 20% 50%, rgba(14,165,233,0.08) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 20%, rgba(245,158,11,0.06) 0%, transparent 50%),
      #0B1220;
  "></div>

  <!-- Content area -->
  <div style="position: relative; z-index: 2; height: 100%; display: flex; flex-direction: column; padding: 28mm 18mm 20mm 18mm;">

    <!-- Top: Edition number + date -->
    <div style="display: flex; justify-content: space-between; align-items: center;">
      <div class="print-cover-edition">
        Edition #{edition.number}
      </div>
      <div class="print-cover-date">
        {dateRange}
      </div>
    </div>

    <!-- Nameplate -->
    <div style="margin-top: 8pt;">
      <div class="print-cover-nameplate">
        MERIDIAN
      </div>
      <div style="font-family: 'Inter', sans-serif; font-size: 8pt; letter-spacing: 4pt; text-transform: uppercase; color: rgba(255,255,255,0.4); margin-top: 4pt;">
        Your World, Synthesized
      </div>
    </div>

    <!-- Hero Image — contained, not full-bleed -->
    <div style="margin-top: 12pt; width: 100%; flex-shrink: 0;">
      <img
        src={edition.coverImage}
        alt={edition.title}
        style="
          width: 100%;
          height: auto;
          display: block;
          border-radius: 4pt;
          object-fit: contain;
          max-height: 120mm;
        "
      />
    </div>

    <!-- Headline -->
    <div style="margin-top: 14pt;">
      {edition.subtitle && (
        <div style="font-family: 'Inter', sans-serif; font-size: 9pt; font-weight: 600; letter-spacing: 2pt; text-transform: uppercase; color: #0EA5E9; margin-bottom: 8pt;">
          Cover Story
        </div>
      )}
      <h1 class="print-cover-headline">
        {edition.title}
      </h1>
      {edition.subtitle && (
        <p class="print-cover-subtitle">
          {edition.subtitle}
        </p>
      )}
    </div>

    <!-- Article teasers -->
    {edition.articles && edition.articles.length > 0 && (
      <div style="margin-top: 14pt; display: flex; flex-direction: column; gap: 5pt;">
        <div style="width: 28pt; height: 1.5pt; background: #0EA5E9;"></div>
        {edition.articles.slice(0, 5).map((article) => (
          <div style="display: flex; align-items: baseline; gap: 8pt; font-size: 8pt;">
            <span style="color: #0EA5E9; font-weight: 600; font-family: 'Inter', sans-serif; min-width: 10pt;">
              {article.category ? '●' : '○'}
            </span>
            <span style="font-family: 'Playfair Display', Georgia, serif; color: rgba(255,255,255,0.9); font-weight: 500;">
              {article.title}
            </span>
            {article.author && (
              <span style="font-family: 'Inter', sans-serif; color: rgba(255,255,255,0.4); font-size: 7pt; margin-left: auto; white-space: nowrap;">
                {article.author.name}
              </span>
            )}
          </div>
        ))}
        <div style="width: 28pt; height: 1.5pt; background: #0EA5E9;"></div>
      </div>
    )}

    <!-- Bottom branding -->
    <div style="margin-top: auto; display: flex; justify-content: space-between; align-items: flex-end;">
      <div style="font-family: 'Inter', sans-serif; font-size: 7pt; color: rgba(255,255,255,0.3); letter-spacing: 1pt;">
        meridian-mag.com
      </div>
      <div style="display: flex; align-items: center; gap: 6pt;">
        <div style="width: 32pt; height: 32pt; border: 1pt solid rgba(255,255,255,0.2); border-radius: 4pt; display: flex; align-items: center; justify-content: center;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.5)" stroke-width="1.5">
            <rect x="3" y="3" width="7" height="7" rx="1"/>
            <rect x="14" y="3" width="7" height="7" rx="1"/>
            <rect x="3" y="14" width="7" height="7" rx="1"/>
            <rect x="14" y="14" width="7" height="7" rx="1"/>
          </svg>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom accent stripe -->
  <div style="
    position: absolute; bottom: 0; left: 0; right: 0; height: 3pt;
    background: linear-gradient(90deg, #0EA5E9 0%, #F59E0B 100%);
    z-index: 2;
  "></div>
</div>
