---
// Nav.astro
// Desktop horizontal navigation links.
// Renders category links from site config with hover states.
// Hidden on mobile (mobile uses MobileMenu instead).
import { getSiteConfig } from '@data/service';

const { navLinks } = await getSiteConfig();
---

<nav class="hidden lg:flex items-center gap-1" aria-label="Main navigation">
  {navLinks.map(link => {
    const isActive = link.href === Astro.url.pathname || (link.href !== '/' && Astro.url.pathname.startsWith(link.href));
    return (
    <a
      href={link.href}
      class:list={[
        'px-3 py-2 text-sm font-medium transition-colors',
        isActive
          ? 'text-accent dark:text-accent-light font-bold'
          : 'text-text-secondary dark:text-gray-400 hover:text-primary dark:hover:text-white',
      ]}
      {...isActive && { 'aria-current': 'page' }}
    >
      {link.label}
      {link.access === 'premium' && (
        <span class="ml-1 inline-flex" title="Premium content">
          <svg class="w-3 h-3 text-accent-warm" fill="currentColor" viewBox="0 0 24 24">
            <path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zM12 17c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"/>
          </svg>
        </span>
      )}
    </a>
    );
  })}
  <a href="/editorial" class:list={["flex items-center gap-1 px-3 py-2 text-sm font-medium transition-colors", Astro.url.pathname.startsWith("/editorial") ? "text-accent dark:text-accent-light font-bold" : "text-text-secondary dark:text-gray-400 hover:text-accent dark:hover:text-accent-light"]} {...Astro.url.pathname.startsWith("/editorial") && { "aria-current": "page" }}>
    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
    </svg>
    Editorial
  </a>
  </nav>
