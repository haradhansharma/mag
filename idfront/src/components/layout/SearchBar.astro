---
// SearchBar.astro
// Alpine.js search toggle with dropdown, input, and quick results.
// Quick results rendered from trending articles via service layer.
// Escape key dismisses the dropdown.
import { getTrendingArticles } from '@data/service';
import { getInitials, formatDate } from '@utils/helpers';

const trendingArticles = (await getTrendingArticles()).slice(0, 3);
---

<div class="relative" x-data="{ searchOpen: false, searchQuery: '' }">
  <!-- Search icon toggle -->
  <button
    @click="searchOpen = !searchOpen"
    class="touch-target p-2 text-text-secondary dark:text-gray-400 hover:text-primary dark:hover:text-white transition-colors rounded-lg"
    aria-label="Search"
    aria-expanded="false"
    :aria-expanded="searchOpen"
  >
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
    </svg>
  </button>

  <!-- Search dropdown -->
  <div
    x-show="searchOpen"
    x-transition.opacity.duration.150ms
    @click.outside="searchOpen = false"
    role="search"
    aria-label="Search articles"
    class="absolute right-0 top-12 w-72 sm:w-96 max-w-[calc(100vw-2rem)] bg-white dark:bg-gray-900 border border-border dark:border-gray-700 rounded-xl shadow-xl p-4 animate-slide-down z-50"
  >
    <form action="/search" method="get" class="relative">
      <label for="search-input" class="sr-only">Search articles</label>
      <input
        type="text"
        id="search-input"
        name="q"
        x-model="searchQuery"
        placeholder="Search articles, topics, authors..."
        class="w-full px-4 py-2.5 bg-surface dark:bg-gray-800 border border-border dark:border-gray-700 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent dark:text-white"
        @keydown.escape="searchOpen = false"
      />
    </form>

    <!-- Quick results (shown when typing) -->
    <div x-show="searchQuery.length > 0" class="mt-3 space-y-1">
      <p class="text-xs text-text-muted dark:text-gray-500 px-2 mb-2">Quick results</p>

      {trendingArticles.map(article => (
        <a
          href={`/articles/${article.slug}`}
          class="w-full text-left px-3 py-2 rounded-lg hover:bg-surface-alt dark:hover:bg-gray-800 transition-colors block"
        >
          <p class="text-sm font-medium dark:text-white">{article.title}</p>
          <p class="text-xs text-text-muted dark:text-gray-500">
            {article.category?.name} &middot; {article.author?.name}
          </p>
        </a>
      ))}

      <a
        href={`/search?q=${encodeURIComponent('')}`}
        x-bind:href="'/search?q=' + encodeURIComponent(searchQuery)"
        class="block w-full text-center px-3 py-2 text-sm font-medium text-accent hover:text-sky-600 transition-colors rounded-lg hover:bg-surface-alt dark:hover:bg-gray-800"
      >
        Search for &ldquo;<span x-text="searchQuery"></span>&rdquo; &rarr;
      </a>
    </div>

    <!-- Default suggestions (shown when input is empty) -->
    <div x-show="searchQuery.length === 0" class="mt-3 space-y-1">
      <p class="text-xs text-text-muted dark:text-gray-500 px-2 mb-2">Trending</p>
      {trendingArticles.map(article => (
        <a
          href={`/articles/${article.slug}`}
          class="w-full text-left px-3 py-2 rounded-lg hover:bg-surface-alt dark:hover:bg-gray-800 transition-colors block"
        >
          <p class="text-sm font-medium dark:text-white">{article.title}</p>
          <p class="text-xs text-text-muted dark:text-gray-500">
            {article.category?.name} &middot; {article.author?.name}
          </p>
        </a>
      ))}
    </div>
  </div>
</div>
