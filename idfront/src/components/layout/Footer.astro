---
// Footer.astro
// 4-column grid: About, Categories, Subscribe, Follow.
// Uses site config for dynamic links and categories.
import { getSiteConfig, getPublicCategories } from '@data/service';

const { footerLinks, socialLinks } = await getSiteConfig();
const publicCategories = await getPublicCategories();
const currentYear = new Date().getFullYear();

// Social icon SVG paths
const socialIcons: Record<string, string> = {
  twitter: 'M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z',
  instagram: 'M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z',
  youtube: 'M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z',
  rss: 'M6 5c7.18 0 13 5.82 13 13M6 11a7 7 0 017 7m-6 0a1 1 0 11-2 0 1 1 0 012 0z',
  linkedin: 'M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z',
};
---

<footer class="bg-primary dark:bg-gray-950 text-gray-300 mt-16" role="contentinfo">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">

      <!-- Column 1: About -->
      <div>
        <div class="flex items-center gap-2 mb-4">
          <div class="w-7 h-7 bg-accent rounded-sm flex items-center justify-center">
            <span class="text-white font-bold text-xs font-editorial">M</span>
          </div>
          <span class="font-editorial text-lg font-bold text-white">MERIDIAN</span>
        </div>
        <p class="text-sm text-gray-400 leading-relaxed mb-4">
          Your World, Synthesized. A daily knowledge magazine for the curious mind.
        </p>
        <p class="text-xs text-gray-500">&copy; {currentYear} MERIDIAN Magazine. All rights reserved.</p>
      </div>

      <!-- Column 2: Categories -->
      <div>
        <h4 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Categories</h4>
        <ul class="space-y-2">
          {publicCategories.map(cat => (
            <li>
              <a
                href={`/categories/${cat.slug}`}
                class="text-sm text-gray-400 hover:text-accent transition-colors"
              >
                {cat.name}
              </a>
            </li>
          ))}
          <li>
            <a href="/categories/opinion-analysis" class="text-sm text-gray-400 hover:text-accent transition-colors flex items-center gap-1">
              Opinion & Analysis
              <svg class="w-3 h-3 text-accent-warm" fill="currentColor" viewBox="0 0 24 24">
                <path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zM12 17c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"/>
              </svg>
            </a>
          </li>
        </ul>
      </div>

      <!-- Column 3: Subscribe & Links -->
      <div>
        <h4 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Subscribe</h4>
        <ul class="space-y-2">
          <li><a href="/subscribe" class="text-sm text-gray-400 hover:text-accent transition-colors">All Plans</a></li>
          <li><a href="/subscribe/pricing" class="text-sm text-gray-400 hover:text-accent transition-colors">Compare Pricing</a></li>
          <li><a href="/print/order" class="text-sm text-gray-400 hover:text-accent transition-colors">Print Edition</a></li>
          <li><a href="/editions/archive" class="text-sm text-gray-400 hover:text-accent transition-colors">Edition Archive</a></li>
          <li><a href="/rss.xml" class="text-sm text-gray-400 hover:text-accent transition-colors">RSS Feed</a></li>
        </ul>
      </div>

      <!-- Column 4: Follow Us -->
      <div>
        <h4 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Follow Us</h4>
        <div class="flex gap-3 mb-4">
          {socialLinks.map(social => (
            <a
              href={social.url}
              class="w-9 h-9 rounded-lg bg-gray-800 hover:bg-accent flex items-center justify-center transition-colors"
              aria-label={social.label}
              title={social.label}
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d={socialIcons[social.platform] || ''} />
              </svg>
            </a>
          ))}
        </div>
        <p class="text-xs text-gray-500">
          Stay connected with MERIDIAN for daily insights.
        </p>
      </div>
    </div>
  </div>
</footer>
