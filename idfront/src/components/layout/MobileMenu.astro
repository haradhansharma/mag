---
// MobileMenu.astro
// Alpine.js hamburger toggle with slide-down animation.
// Shows all navigation links + extra pages (Editions, Subscribe, Print).
// Only visible on mobile (lg:hidden).
// IMPORTANT: This component inherits x-data="{ mobileMenu: false }" from
// the parent <nav> in Header.astro — do NOT add x-data here.
import { getSiteConfig } from '@data/service';

const { navLinks } = await getSiteConfig();
---

<div
  x-show="mobileMenu"
  x-transition:enter="transition ease-out duration-200"
  x-transition:enter-start="opacity-0 -translate-y-2"
  x-transition:enter-end="opacity-100 translate-y-0"
  x-transition:leave="transition ease-in duration-150"
  x-transition:leave-start="opacity-100 translate-y-0"
  x-transition:leave-end="opacity-0 -translate-y-2"
  x-cloak
  role="navigation"
  aria-label="Mobile navigation"
  class="lg:hidden pb-4 border-t border-border dark:border-gray-800 mt-2 pt-4 animate-slide-down"
>
  <div class="flex flex-col gap-1">
    <!-- Home -->
    <a href="/" class="px-4 py-3 text-left text-sm font-medium rounded-lg hover:bg-surface-alt dark:hover:bg-gray-800 transition-colors">
      Home
    </a>

    <!-- Category links -->
    {navLinks.map(link => (
      <a href={link.href} class="px-4 py-3 text-left text-sm font-medium rounded-lg hover:bg-surface-alt dark:hover:bg-gray-800 transition-colors flex items-center justify-between">
        {link.label}
        {link.access === 'premium' && (
          <svg class="w-3.5 h-3.5 text-accent-warm" fill="currentColor" viewBox="0 0 24 24">
            <path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zM12 17c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"/>
          </svg>
        )}
      </a>
    ))}

    <hr class="my-2 border-border dark:border-gray-800" />

    <!-- Extra pages -->
    <a href="/editions/archive" class="px-4 py-3 text-left text-sm font-medium rounded-lg hover:bg-surface-alt dark:hover:bg-gray-800 transition-colors">
      All Editions
    </a>
    <a href="/editorial" class="px-4 py-3 text-left text-sm font-medium rounded-lg hover:bg-surface-alt dark:hover:bg-gray-800 transition-colors">
      Editorial Dashboard
    </a>
    <a href="/subscribe" class="px-4 py-3 text-left text-sm font-medium rounded-lg hover:bg-surface-alt dark:hover:bg-gray-800 transition-colors">
      Subscribe
    </a>
    <a href="/print/order" class="px-4 py-3 text-left text-sm font-medium rounded-lg hover:bg-surface-alt dark:hover:bg-gray-800 transition-colors">
      Print Edition
    </a>

    <hr class="my-2 border-border dark:border-gray-800" />

    <!-- Account: Login or Logout (conditional) -->
    <template x-if="!localStorage.getItem('meridian_token')">
      <a href="/auth/login" class="px-4 py-3 text-left text-sm font-medium rounded-lg hover:bg-surface-alt dark:hover:bg-gray-800 transition-colors flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
        </svg>
        Login / Register
      </a>
    </template>
    <template x-if="localStorage.getItem('meridian_token')">
      <div>
        <div class="px-4 py-2 flex items-center gap-2">
          <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
          </svg>
          <span class="text-sm font-semibold text-accent" x-text="JSON.parse(localStorage.getItem('meridian_user') || '{}').username || 'User'"></span>
        </div>
        <button
          @click="handleLogout()"
          class="w-full px-4 py-3 text-left text-sm font-medium rounded-lg hover:bg-red-50 dark:hover:bg-red-900/20 hover:text-red-500 dark:hover:text-red-400 transition-colors flex items-center gap-2"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
          </svg>
          Logout
        </button>
      </div>
    </template>
  </div>
</div>
