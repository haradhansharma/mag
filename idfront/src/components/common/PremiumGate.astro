---
// PremiumGate.astro
// Alpine.js-powered premium content gate/paywall.
// Full content is NOT embedded in static HTML — it is fetched via API
// only after the user authenticates and has a premium role.
// This prevents premium content from leaking in page source.

interface Props {
  previewContent: string;  // HTML excerpt shown before paywall
  articleSlug: string;     // Article slug to fetch full content from API
}

const { previewContent, articleSlug } = Astro.props;
---

<div x-data="{ showPremium: false, checking: false, fullContent: '' }">
  <!-- Preview with fade mask -->
  <div x-show="!showPremium" class="relative">
    <div class="fade-bottom" set:html={previewContent}></div>
    <div class="absolute bottom-0 left-0 right-0 h-40 bg-gradient-to-t from-surface dark:from-gray-950 to-transparent"></div>
  </div>

  <!-- Full content (fetched dynamically, hidden until auth verified) -->
  <div x-show="showPremium" x-cloak x-transition.opacity>
    <div id="premium-content-slot" set:html={previewContent}></div>
  </div>

  <!-- Paywall CTA card -->
  <div x-show="!showPremium" class="mt-8 mb-16">
    <div class="premium-glow dark:from-amber-900/20 dark:to-blue-900/10 rounded-2xl border border-accent-warm/30 dark:border-amber-700/40 p-8 text-center">
      <div class="w-12 h-12 bg-accent-warm/10 dark:bg-amber-900/30 rounded-full flex items-center justify-center mx-auto mb-4">
        <svg class="w-6 h-6 text-accent-warm" fill="currentColor" viewBox="0 0 24 24"><path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zM12 17c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"/></svg>
      </div>
      <h3 class="font-editorial text-2xl font-bold mb-2">Continue Reading</h3>
      <p class="text-text-secondary dark:text-gray-400 mb-6">This article is for premium subscribers. Unlock full access to all stories, editions, and exclusive content.</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/subscribe" class="px-6 py-3 bg-accent hover:bg-sky-600 text-white font-semibold rounded-lg transition-colors shadow-md">Subscribe — $4.99/month</a>
        <button
          @click="
            checking = true;
            const token = localStorage.getItem('meridian_token');
            const userData = localStorage.getItem('meridian_user');
            if (!token || !userData) {
              window.location.href = '/auth/login?next=' + encodeURIComponent(window.location.pathname);
              return;
            }
            try {
              const user = JSON.parse(userData);
              const premiumRoles = ['subscriber', 'admin', 'editor', 'writer'];
              if (premiumRoles.includes(user.role)) {
                // Fetch full article content from API
                const API_BASE = 'http://localhost:8085/api/v1';
                fetch(API_BASE + '/articles/{articleSlug}', {
                  headers: { 'Authorization': 'Bearer ' + token }
                })
                .then(res => {
                  if (!res.ok) throw new Error('Failed to fetch');
                  return res.json();
                })
                .then(data => {
                  fullContent = data.content || '';
                  document.getElementById('premium-content-slot').innerHTML = fullContent;
                  showPremium = true;
                })
                .catch(() => {
                  window.location.href = '/auth/login?next=' + encodeURIComponent(window.location.pathname);
                });
              } else {
                window.location.href = '/subscribe';
              }
            } catch(e) {
              window.location.href = '/auth/login?next=' + encodeURIComponent(window.location.pathname);
            }
            checking = false;
          "
          :disabled="checking"
          class="px-6 py-3 border border-border dark:border-gray-600 text-text-secondary dark:text-gray-400 hover:bg-surface dark:hover:bg-gray-800 font-semibold rounded-lg transition-colors"
        >
          <span x-show="!checking">Preview Full Article</span>
          <span x-show="checking" x-cloak>Verifying...</span>
        </button>
      </div>
    </div>
  </div>
</div>
