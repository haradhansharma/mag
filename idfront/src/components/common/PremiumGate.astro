---
// PremiumGate.astro
// Alpine.js-powered premium content gate/paywall.
// Wraps premium article content with a fade-bottom mask and a CTA card.

interface Props {
  previewContent: string;  // HTML excerpt shown before paywall
  fullContent: string;     // Full HTML behind paywall
}

const { previewContent, fullContent } = Astro.props;
---

<div x-data="{ showPremium: false }">
  <!-- Preview with fade mask -->
  <div x-show="!showPremium" class="relative">
    <div class="fade-bottom" set:html={previewContent}></div>
    <div class="absolute bottom-0 left-0 right-0 h-40 bg-gradient-to-t from-surface dark:from-gray-950 to-transparent"></div>
  </div>

  <!-- Full content (hidden by default) -->
  <div x-show="showPremium" x-cloak x-transition.opacity>
    <Fragment set:html={fullContent}></Fragment>
  </div>

  <!-- Paywall CTA card -->
  <div x-show="!showPremium" class="mt-8 mb-16">
    <div class="premium-glow dark:from-amber-900/20 dark:to-blue-900/10 rounded-2xl border border-accent-warm/30 dark:border-amber-700/40 p-8 text-center">
      <div class="w-12 h-12 bg-accent-warm/10 dark:bg-amber-900/30 rounded-full flex items-center justify-center mx-auto mb-4">
        <svg class="w-6 h-6 text-accent-warm" fill="currentColor" viewBox="0 0 24 24"><path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zM12 17c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"/></svg>
      </div>
      <h3 class="font-editorial text-2xl font-bold mb-2">Continue Reading</h3>
      <p class="text-text-secondary dark:text-gray-400 mb-6">This article is for premium subscribers. Unlock full access to all stories, editions, and exclusive content.</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/subscribe" class="px-6 py-3 bg-accent hover:bg-sky-600 text-white font-semibold rounded-lg transition-colors shadow-md">Subscribe — $4.99/month</a>
        <button @click="showPremium = true" class="px-6 py-3 border border-border dark:border-gray-600 text-text-secondary dark:text-gray-400 hover:bg-surface dark:hover:bg-gray-800 font-semibold rounded-lg transition-colors">Preview Full Article</button>
      </div>
    </div>
  </div>
</div>
