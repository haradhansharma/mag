---
// ============================================================
// MERIDIAN Magazine — ArticleCard Component
// ============================================================
// Reusable article card with 3 display variants:
//   'featured' — Large hero card (homepage top story)
//   'compact'  — Horizontal sidebar card (image left, text right)
//   'grid'     — Standard grid card (category listings, 3-col grids)
// ============================================================

import type { Article } from '@data/types';
import { getInitials, formatDate, getCategoryColorClasses } from '@utils/helpers';

interface Props {
  article: Article;
  variant?: 'featured' | 'compact' | 'grid';
  showPremiumBadge?: boolean;
  index?: number;
}

const {
  article,
  variant = 'grid',
  showPremiumBadge = true,
  index,
} = Astro.props;

const categoryColor = getCategoryColorClasses(article.category?.color || 'blue');
const initials = getInitials(article.author?.name || 'M');
const isPremium = article.access === 'premium';
---

{/* ====== FEATURED VARIANT ====== */}
{variant === 'featured' && (
  <a href={`/articles/${article.slug}`} class:list={['lg:col-span-7 group block']}>
    <div class="bg-white dark:bg-gray-900 rounded-2xl overflow-hidden card-hover border border-border dark:border-gray-800">
      <!-- Image -->
      <div class="relative h-64 sm:h-80 overflow-hidden">
        <img
          src={article.coverImage}
          alt={article.title}
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
          fetchpriority="high"
          width="800"
          height="500"
        />
        <!-- Badges at top-left -->
        <div class="absolute top-4 left-4 flex gap-2">
          <span class:list={['px-2.5 py-1 text-white text-xs font-bold rounded-md uppercase', categoryColor.bg]}>
            {article.category?.name || 'Uncategorized'}
          </span>
          {isPremium && showPremiumBadge && (
            <span class="px-2.5 py-1 bg-accent-warm text-white text-xs font-bold rounded-md uppercase flex items-center gap-1">
              <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zM12 17c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"/></svg>
              Premium
            </span>
          )}
        </div>
      </div>
      <!-- Content -->
      <div class="p-6">
        <h3 class="font-editorial text-xl sm:text-2xl font-bold mb-2 group-hover:text-accent transition-colors">
          {article.title}
        </h3>
        <p class="text-text-secondary dark:text-gray-400 mb-4 line-clamp-2">
          {article.excerpt}
        </p>
        <div class="flex items-center gap-3">
          <!-- Author avatar (initials) -->
          <div class="w-8 h-8 rounded-full bg-gradient-to-br from-accent to-blue-700 flex items-center justify-center text-white text-xs font-bold flex-shrink-0">
            {initials}
          </div>
          <div>
            <p class="text-sm font-semibold">{article.author?.name || 'Staff'}</p>
            <p class="text-xs text-text-muted dark:text-gray-500">
              {article.readingTime} min read &middot; {formatDate(article.publishedAt, 'medium')}
            </p>
          </div>
        </div>
      </div>
    </div>
  </a>
)}

{/* ====== COMPACT VARIANT ====== */}
{variant === 'compact' && (
  <a href={`/articles/${article.slug}`} class="group block">
    <div class="bg-white dark:bg-gray-900 rounded-2xl overflow-hidden card-hover border border-border dark:border-gray-800 flex flex-row h-40 sm:h-48">
      <!-- Image -->
      <div class="w-2/5 overflow-hidden flex-shrink-0">
        <img
          src={article.coverImage}
          alt={article.title}
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
          loading="lazy"
          width="320"
          height="240"
        />
      </div>
      <!-- Content -->
      <div class="p-4 flex flex-col justify-center flex-1 min-w-0">
        <span class:list={['text-[10px] font-bold uppercase tracking-wider mb-1', categoryColor.text]}>
          {article.category?.name || 'Uncategorized'}
        </span>
        <h3 class="font-editorial text-lg font-bold mb-1.5 line-clamp-2 group-hover:text-accent transition-colors">
          {article.title}
        </h3>
        <p class="text-xs text-text-muted dark:text-gray-500">
          {article.author?.name || 'Staff'} &middot; {article.readingTime} min read
        </p>
      </div>
    </div>
  </a>
)}

{/* ====== GRID VARIANT ====== */}
{variant === 'grid' && (
  <a href={`/articles/${article.slug}`} class="group text-left block">
    <div class="bg-surface dark:bg-gray-800 rounded-xl overflow-hidden card-hover border border-border dark:border-gray-700">
      <!-- Image -->
      <div class="h-48 overflow-hidden relative">
        <img
          src={article.coverImage}
          alt={article.title}
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
          loading="lazy"
          width="400"
          height="300"
        />
        <div class="absolute top-3 left-3 flex gap-2">
          <span class:list={['px-2 py-0.5 text-white text-[10px] font-bold rounded uppercase', categoryColor.bg]}>
            {article.category?.name || 'Uncategorized'}
          </span>
          {isPremium && showPremiumBadge && (
            <span class="px-2 py-0.5 bg-accent-warm text-white text-[10px] font-bold rounded uppercase flex items-center gap-1">
              <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zM12 17c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"/></svg>
              Premium
            </span>
          )}
        </div>
      </div>
      <!-- Content -->
      <div class="p-5">
        <h3 class="font-editorial text-lg font-bold mb-2 group-hover:text-accent transition-colors">
          {article.title}
        </h3>
        <p class="text-sm text-text-secondary dark:text-gray-400 line-clamp-2">
          {article.excerpt}
        </p>
        <div class="flex items-center gap-2 mt-4">
          <div class="w-6 h-6 rounded-full bg-gradient-to-br from-accent to-blue-700 flex items-center justify-center text-white text-[10px] font-bold flex-shrink-0">
            {initials}
          </div>
          <span class="text-xs text-text-muted dark:text-gray-500">
            {article.author?.name || 'Staff'} &middot; {article.readingTime} min read
          </span>
        </div>
      </div>
    </div>
  </a>
)}
