---
/**
 * Pagination.astro
 *
 * Numbered page navigation with prev/next arrows and smart ellipsis.
 *
 * Props:
 *   currentPage — Current active page number (1-based)
 *   totalPages  — Total number of pages
 *   basePath    — Base URL path (e.g. "/categories/science-tech")
 *                 Page links are built as ${basePath}?page=${n}
 */

interface Props {
  currentPage: number;
  totalPages: number;
  basePath: string;
}

const { currentPage, totalPages, basePath } = Astro.props;

const prevDisabled = currentPage <= 1;
const nextDisabled = currentPage >= totalPages;

/**
 * Build the set of page numbers to display with ellipsis.
 * Always shows: first, last, current, current±1
 */
function getPageNumbers(current: number, total: number): Array<number | '...'> {
  if (total <= 7) {
    // Show all pages if 7 or fewer
    return Array.from({ length: total }, (_, i) => i + 1);
  }

  const pages: Array<number | '...'> = [];

  // Always include first page
  pages.push(1);

  // Determine range around current page
  const rangeStart = Math.max(2, current - 1);
  const rangeEnd = Math.min(total - 1, current + 1);

  // Add ellipsis before range if needed
  if (rangeStart > 2) {
    pages.push('...');
  }

  // Add pages in range
  for (let i = rangeStart; i <= rangeEnd; i++) {
    pages.push(i);
  }

  // Add ellipsis after range if needed
  if (rangeEnd < total - 1) {
    pages.push('...');
  }

  // Always include last page
  if (total > 1) {
    pages.push(total);
  }

  return pages;
}

const pageNumbers = getPageNumbers(currentPage, totalPages);
---

{totalPages > 1 && (
  <div class="flex items-center justify-center gap-2 mt-10">
    {/* Previous arrow */}
    {prevDisabled ? (
      <span
        class="w-10 h-10 rounded-lg border border-border dark:border-gray-700 flex items-center justify-center text-text-muted/50 dark:text-gray-600 cursor-not-allowed"
        aria-disabled="true"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
      </span>
    ) : (
      <a
        href={`${basePath}?page=${currentPage - 1}`}
        class="w-10 h-10 rounded-lg border border-border dark:border-gray-700 flex items-center justify-center text-text-muted dark:text-gray-500 hover:bg-surface dark:hover:bg-gray-800 transition-colors"
        aria-label="Previous page"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
      </a>
    )}

    {/* Page numbers */}
    {pageNumbers.map((page) => {
      if (page === '...') {
        return (
          <span class="w-10 h-10 flex items-center justify-center text-text-muted dark:text-gray-500 select-none">
            …
          </span>
        );
      }

      const isCurrent = page === currentPage;

      return isCurrent ? (
        <span
          class="w-10 h-10 rounded-lg bg-accent text-white font-semibold text-sm flex items-center justify-center"
          aria-current="page"
        >
          {page}
        </span>
      ) : (
        <a
          href={`${basePath}?page=${page}`}
          class="w-10 h-10 rounded-lg border border-border dark:border-gray-700 text-text-secondary dark:text-gray-400 hover:bg-surface dark:hover:bg-gray-800 font-semibold text-sm flex items-center justify-center transition-colors"
        >
          {page}
        </a>
      );
    })}

    {/* Next arrow */}
    {nextDisabled ? (
      <span
        class="w-10 h-10 rounded-lg border border-border dark:border-gray-700 flex items-center justify-center text-text-muted/50 dark:text-gray-600 cursor-not-allowed"
        aria-disabled="true"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </span>
    ) : (
      <a
        href={`${basePath}?page=${currentPage + 1}`}
        class="w-10 h-10 rounded-lg border border-border dark:border-gray-700 flex items-center justify-center text-text-muted dark:text-gray-500 hover:bg-surface dark:hover:bg-gray-800 transition-colors"
        aria-label="Next page"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    )}
  </div>
)}
