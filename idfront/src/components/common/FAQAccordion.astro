---
/**
 * FAQAccordion.astro
 * Collapsible FAQ list powered by Alpine.js.
 *
 * Props:
 *   items: Array<{ question: string; answer: string }>
 *
 * Uses x-transition instead of x-collapse (no plugin dependency).
 */

interface Props {
  items: Array<{ question: string; answer: string }>;
}

const { items } = Astro.props;
---

<div x-data={`{ openFaq: null }`} class="space-y-3">
  {items.map((item, index) => (
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-border dark:border-gray-800 overflow-hidden">
      <button
        @click={`openFaq = openFaq === ${index} ? null : ${index}`}
        class="w-full flex items-center justify-between p-5 text-left hover:bg-surface dark:hover:bg-gray-800 transition-colors"
        aria-expanded="false"
      >
        <span class="font-semibold text-sm pr-4">{item.question}</span>
        <svg
          class="w-5 h-5 text-text-muted dark:text-gray-500 flex-shrink-0 transition-transform duration-200"
          :class={`openFaq === ${index} ? 'rotate-180' : ''`}
          x-cloak
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </button>
      <div
        x-show={`openFaq === ${index}`}
        x-transition:enter="transition ease-out duration-200"
        x-transition:enter-start="opacity-0 -translate-y-2"
        x-transition:enter-end="opacity-100 translate-y-0"
        x-transition:leave="transition ease-in duration-150"
        x-transition:leave-start="opacity-100 translate-y-0"
        x-transition:leave-end="opacity-0 -translate-y-2"
        x-cloak
        class="px-5 pb-5"
      >
        <p class="text-sm text-text-secondary dark:text-gray-400 leading-relaxed">
          {item.answer}
        </p>
      </div>
    </div>
  ))}
</div>
