---
/**
 * Breadcrumbs.astro
 *
 * Navigation breadcrumb trail for pages.
 *
 * Props:
 *   items — Array of { label: string, href?: string }
 *           The last item is the current page (no link, normal text color).
 *           The first item typically gets a back arrow icon.
 */

interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="flex items-center flex-wrap gap-x-1 gap-y-1">
  {items.map((item, index) => {
    const isFirst = index === 0;
    const isLast = index === items.length - 1;

    return (
      <>
        {index > 0 && (
          <span class="text-text-muted dark:text-gray-500 mx-1" aria-hidden="true">›</span>
        )}

        {isLast ? (
          <span class="text-sm text-text-primary dark:text-gray-200 font-medium">
            {item.label}
          </span>
        ) : (
          <a
            href={item.href || '/'}
            class="inline-flex items-center gap-1 text-sm text-text-muted dark:text-gray-500 hover:text-accent dark:hover:text-accent-light transition-colors"
          >
            {isFirst && (
              <svg
                class="w-4 h-4 flex-shrink-0"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M15 19l-7-7 7-7"
                />
              </svg>
            )}
            {item.label}
          </a>
        )}
      </>
    );
  })}
</nav>
