---
/**
 * PricingCard.astro
 * Individual subscription pricing card with monthly/yearly toggle (Alpine.js).
 *
 * Props:
 *   plan: SubscriptionPlan
 *   isPopular?: boolean — adds "Most Popular" badge, ring, shadow
 *   annualSavings?: string — e.g. "Save $20/year"
 */

import type { SubscriptionPlan } from '@data/types';

interface Props {
  plan: SubscriptionPlan;
  isPopular?: boolean;
  annualSavings?: string;
}

const { plan, isPopular = false, annualSavings } = Astro.props;

/**
 * Human-readable description for each plan type.
 */
function getPlanDescription(type: SubscriptionPlan['type']): string {
  const descriptions: Record<SubscriptionPlan['type'], string> = {
    free: 'Explore MERIDIAN with limited access',
    premium: 'Full digital access to everything',
    print: 'Weekly print edition delivered',
    premium_print: 'Digital + Print — the complete experience',
  };
  return descriptions[type];
}

/**
 * Monthly price equivalent when showing annual.
 * Annual plan has price = yearly total, so monthly = price / 12.
 */
const isFreePlan = plan.price === 0;
const isAnnualPlan = plan.interval === 'yearly';
const annualPrice = isAnnualPlan ? plan.price : plan.price * 12;
const monthlyEquivalent = (annualPrice / 12).toFixed(2);
---

<div
  class:list={[
    'relative bg-white dark:bg-gray-900 rounded-2xl p-8 border border-border dark:border-gray-700 transition-all duration-300',
    isPopular
      ? 'ring-2 ring-accent dark:ring-accent shadow-xl scale-[1.02] lg:scale-105 z-10'
      : 'card-hover',
  ]}
  x-data="{ annual: false }"
>
  <!-- Most Popular badge -->
  {isPopular && (
    <div class="absolute -top-4 left-1/2 -translate-x-1/2">
      <span class="inline-flex items-center px-4 py-1.5 bg-accent text-white text-xs font-bold rounded-full shadow-md">
        <svg class="w-3.5 h-3.5 mr-1.5" fill="currentColor" viewBox="0 0 20 20">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
        </svg>
        Most Popular
      </span>
    </div>
  )}

  <!-- Plan name & description -->
  <h3 class="text-xl font-bold mb-1 text-text-primary dark:text-gray-100">{plan.name}</h3>
  <p class="text-text-muted dark:text-gray-500 text-sm mb-6">
    {getPlanDescription(plan.type)}
  </p>

  <!-- Monthly / Yearly toggle (only for paid plans) -->
  {!isFreePlan && (
    <div class="flex items-center justify-center gap-3 mb-6">
      <span
        class:list={[
          'text-sm font-medium transition-colors',
          'text-text-secondary dark:text-gray-400',
        ]}
        :class="!annual ? 'text-text-primary dark:text-gray-100 font-semibold' : 'text-text-muted dark:text-gray-500'"
      >
        Monthly
      </span>
      <button
        @click="annual = !annual"
        class="relative w-12 h-6 bg-gray-200 dark:bg-gray-700 rounded-full transition-colors focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2"
        :class="annual ? 'bg-accent dark:bg-accent' : ''"
        aria-label="Toggle annual billing"
      >
        <span
          class="absolute top-0.5 left-0.5 w-5 h-5 bg-white dark:bg-gray-200 rounded-full shadow transition-transform duration-200"
          :class="annual ? 'translate-x-6' : 'translate-x-0'"
        ></span>
      </button>
      <span
        class:list={[
          'text-sm font-medium transition-colors',
          'text-text-secondary dark:text-gray-400',
        ]}
        :class="annual ? 'text-text-primary dark:text-gray-100 font-semibold' : 'text-text-muted dark:text-gray-500'"
      >
        Yearly
      </span>
    </div>
  )}

  <!-- Price display -->
  <div class="mb-6 text-center">
    {isFreePlan ? (
      <div>
        <span class="text-4xl font-bold text-text-primary dark:text-gray-100">$0</span>
        <span class="text-text-muted dark:text-gray-500 text-sm"> /forever</span>
      </div>
    ) : (
      <div>
        <!-- Monthly price -->
        <div x-show="!annual">
          <span class="text-4xl font-bold text-text-primary dark:text-gray-100">
            ${isAnnualPlan ? monthlyEquivalent : plan.price.toFixed(2)}
          </span>
          <span class="text-text-muted dark:text-gray-500 text-sm"> /month</span>
        </div>
        <!-- Annual price -->
        <div x-show="annual" x-cloak>
          <span class="text-4xl font-bold text-text-primary dark:text-gray-100">
            ${annualPrice.toFixed(2)}
          </span>
          <span class="text-text-muted dark:text-gray-500 text-sm"> /year</span>
          {annualSavings && (
            <span class="block text-sm font-semibold text-green-600 dark:text-green-400 mt-1">
              {annualSavings}
            </span>
          )}
        </div>
      </div>
    )}
  </div>

  <!-- Feature list -->
  <ul class="space-y-3 mb-8 min-h-[200px]">
    {plan.features.map((feature) => (
      <li class="flex items-start gap-3">
        <svg
          class="w-5 h-5 text-green-500 mt-0.5 flex-shrink-0"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
        <span class="text-sm text-text-secondary dark:text-gray-400">
          {feature}
        </span>
      </li>
    ))}
  </ul>

  <!-- CTA button -->
  <a
    href="/subscribe"
    class:list={[
      'block w-full py-3 text-center font-semibold rounded-lg transition-colors',
      isPopular
        ? 'bg-accent hover:bg-sky-600 text-white shadow-md'
        : 'border border-border dark:border-gray-700 text-text-secondary dark:text-gray-400 hover:bg-surface dark:hover:bg-gray-800',
    ]}
  >
    {isPopular
      ? 'Start Free Trial'
      : isFreePlan
        ? 'Get Started'
        : 'Subscribe Now'}
  </a>
</div>
