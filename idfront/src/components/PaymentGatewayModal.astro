---
/**
 * PaymentGatewayModal.astro
 * Global payment gateway selection modal with TOC consent.
 *
 * Uses Alpine.js x-teleport to render as a fixed overlay.
 * Supports two modes: 'subscription' and 'print_order'.
 *
 * Payment gateways are configurable. Each gateway entry has:
 *   - name: display name
 *   - icon: SVG path (optional)
 *   - url: payment link (Stripe, PayPal, etc.)
 *
 * This component is loaded via BaseLayout so it's available globally.
 * The JS function `paymentGatewayModal()` is auto-initialized.
 */
---

<!-- Payment Gateway Modal (teleported to body) -->
<div
  x-data="paymentGatewayModal()"
  x-show="show"
  x-cloak
  x-transition:enter="transition ease-out duration-300"
  x-transition:enter-start="opacity-0"
  x-transition:enter-end="opacity-100"
  x-transition:leave="transition ease-in duration-200"
  x-transition:leave-start="opacity-100"
  x-transition:leave-end="opacity-0"
  class="fixed inset-0 z-[100] flex items-center justify-center p-4"
  @keydown.escape.window="if (show) close()"
>
  <!-- Backdrop -->
  <div class="fixed inset-0 bg-black/60 backdrop-blur-sm" @click="close()"></div>

  <!-- Modal Content -->
  <div
    class="relative bg-white dark:bg-gray-900 rounded-2xl border border-border dark:border-gray-800 w-full max-w-lg shadow-2xl z-10 max-h-[90vh] overflow-y-auto"
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0 scale-95 translate-y-4"
    x-transition:enter-end="opacity-100 scale-100 translate-y-0"
    x-transition:leave="transition ease-in duration-150"
    x-transition:leave-start="opacity-100 scale-100 translate-y-0"
    x-transition:leave-end="opacity-0 scale-95 translate-y-4"
  >
    <!-- Header -->
    <div class="p-6 border-b border-border dark:border-gray-800">
      <div class="flex items-center justify-between">
        <div>
          <h3 class="font-editorial text-xl font-bold text-text-primary dark:text-gray-100">
            <span x-show="mode === 'subscription'">Subscribe to MERIDIAN</span>
            <span x-show="mode === 'print_order'">Complete Your Print Order</span>
          </h3>
          <p x-show="planLabel" class="text-sm text-text-secondary dark:text-gray-400 mt-1" x-text="planLabel"></p>
        </div>
        <button
          @click="close()"
          class="w-8 h-8 flex items-center justify-center rounded-lg hover:bg-surface dark:hover:bg-gray-800 text-text-muted dark:text-gray-500 transition-colors"
          aria-label="Close modal"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Body -->
    <div class="p-6 space-y-5">
      <!-- TOC Consent -->
      <div class="bg-surface-alt dark:bg-gray-800 rounded-xl p-4">
        <label class="flex items-start gap-3 cursor-pointer">
          <input
            type="checkbox"
            x-model="tocAccepted"
            class="mt-1 w-4 h-4 rounded border-border dark:border-gray-600 text-accent focus:ring-accent dark:bg-gray-700"
          />
          <span class="text-sm text-text-primary dark:text-gray-200 leading-relaxed">
            I agree to the <a href="/terms" class="text-accent hover:underline">Terms of Service</a> and
            <a href="/privacy" class="text-accent hover:underline">Privacy Policy</a>.
            I understand that my payment will be processed securely by the selected payment gateway.
          </span>
        </label>
      </div>

      <!-- Payment Gateway Selection -->
      <div>
        <h4 class="text-sm font-semibold text-text-primary dark:text-gray-100 mb-3">Select Payment Method</h4>
        <div class="space-y-2">
          <template x-for="gw in gateways" :key="gw.id">
            <button
              @click="selectGateway(gw)"
              :class="selectedGateway?.id === gw.id ? 'ring-2 ring-accent border-accent bg-accent/5 dark:bg-accent/10' : 'border-border dark:border-gray-700 hover:border-accent/50'"
              class="w-full flex items-center gap-4 p-4 rounded-xl border transition-all duration-200 text-left"
              :disabled="!tocAccepted"
              :class.disabled="!tocAccepted && 'opacity-50 cursor-not-allowed'"
            >
              <!-- Gateway Icon -->
              <div class="w-10 h-10 rounded-lg bg-surface dark:bg-gray-800 flex items-center justify-center flex-shrink-0">
                <img x-show="gw.icon_url" :src="gw.icon_url" :alt="gw.name" class="w-6 h-6 object-contain" loading="lazy" />
                <svg x-show="!gw.icon_url" class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
                </svg>
              </div>
              <!-- Gateway Info -->
              <div class="flex-1 min-w-0">
                <div class="text-sm font-semibold text-text-primary dark:text-gray-100" x-text="gw.name"></div>
                <div class="text-xs text-text-muted dark:text-gray-500" x-text="gw.description"></div>
              </div>
              <!-- Selected Indicator -->
              <div x-show="selectedGateway?.id === gw.id" class="w-5 h-5 rounded-full bg-accent flex items-center justify-center flex-shrink-0">
                <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
            </button>
          </template>
        </div>
      </div>
    </div>

    <!-- Footer -->
    <div class="p-6 border-t border-border dark:border-gray-800 bg-surface dark:bg-gray-900/50 rounded-b-2xl">
      <button
        @click="proceedToPayment()"
        :disabled="!canProceed()"
        class="w-full py-3.5 bg-accent hover:bg-sky-600 disabled:bg-gray-300 dark:disabled:bg-gray-700 disabled:cursor-not-allowed text-white font-semibold rounded-xl text-sm transition-colors flex items-center justify-center gap-2 shadow-md"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
        </svg>
        <span x-text="submitting ? 'Redirecting...' : 'Proceed to Payment'"></span>
      </button>
      <p class="text-xs text-text-muted dark:text-gray-500 text-center mt-3">
        <svg class="w-3 h-3 inline -mt-0.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
        </svg>
        Secured with 256-bit SSL encryption. You will be redirected to the payment gateway.
      </p>
    </div>
  </div>
</div>

<!-- Alpine.js Payment Gateway Modal Logic -->
<script is:inline>
function paymentGatewayModal() {
  return {
    show: false,
    mode: 'subscription', // 'subscription' or 'print_order'
    planLabel: '',
    tocAccepted: false,
    selectedGateway: null,
    submitting: false,

    // Payment gateways — configurable, add/remove as needed
    // These use payment links (Stripe Payment Links, PayPal.me, etc.)
    gateways: [
      {
        id: 'stripe',
        name: 'Stripe',
        description: 'Pay with credit/debit card, Apple Pay, or Google Pay',
        icon_url: '',
        // Payment link URLs — replace with actual Stripe Payment Links
        subscription_url: 'https://buy.stripe.com/subscribe_placeholder',
        order_url: 'https://buy.stripe.com/payment_placeholder',
      },
      {
        id: 'paypal',
        name: 'PayPal',
        description: 'Pay with PayPal account or debit/credit card',
        icon_url: '',
        subscription_url: 'https://paypal.me/meridian_placeholder',
        order_url: 'https://paypal.me/meridian_placeholder',
      },
    ],

    openModal(mode, label) {
      this.mode = mode;
      this.planLabel = label || '';
      this.tocAccepted = false;
      this.selectedGateway = null;
      this.submitting = false;
      this.show = true;
      document.body.style.overflow = 'hidden';
    },

    close() {
      this.show = false;
      document.body.style.overflow = '';
    },

    selectGateway(gw) {
      if (!this.tocAccepted) return;
      this.selectedGateway = gw;
    },

    canProceed() {
      return this.tocAccepted && this.selectedGateway && !this.submitting;
    },

    proceedToPayment() {
      if (!this.canProceed()) return;
      this.submitting = true;

      // Get the appropriate URL based on mode
      const gw = this.selectedGateway;
      const url = this.mode === 'subscription' ? gw.subscription_url : gw.order_url;

      // Dispatch custom event so calling code can intercept/override
      const detail = { mode: this.mode, gateway: gw.id, url, planLabel: this.planLabel };
      window.dispatchEvent(new CustomEvent('meridian:payment-proceed', { detail }));

      // Redirect to payment gateway (open in new tab so user stays on site)
      window.open(url, '_blank', 'noopener,noreferrer');

      // Close modal after brief delay
      setTimeout(() => {
        this.submitting = false;
        this.close();
      }, 1000);
    },
  };
}
</script>
