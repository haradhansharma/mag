# Django / Docker environment variables for idback
# Copy this file to .env and fill in your project-specific values.

# Django core
SECRET_KEY=your-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# PostgreSQL database
MDB_NAME=meridian_db
MDB_USER=postgres
MDB_PASSWORD=postgres_password
MDB_HOST=mdb
MDB_PORT=5432

# Redis
REDIS_HOST=mredis
REDIS_PORT=6379

# Email configuration
M_EMAIL_HOST=smtp.gmail.com
M_EMAIL_PORT=587
M_EMAIL_USE_TLS=True
M_EMAIL_USE_SSL=False
M_EMAIL_HOST_USER=your-email@example.com
M_EMAIL_HOST_PASSWORD=your-email-password
M_DEFAULT_FROM_EMAIL=no-reply@example.com

# Optional production session cookie name
SESSION_COOKIE_NAME=sessionid
